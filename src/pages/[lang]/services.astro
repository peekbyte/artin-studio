---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import ArrowIcon from '../../components/ui/ArrowIcon.astro';
import DotGrid from '../../components/ui/DotGrid.astro';
import { languages, getTranslations, type Lang } from '../../i18n/translations';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
const t = getTranslations(lang);

const services = [
  {
    num: '01',
    title: t.services.brandingTitle,
    desc: t.services.brandingDesc,
    story: lang === 'pl' 
      ? "Każdy silny biznes zaczyna się od jasnej tożsamości. Budujemy systemy brandingowe, które działają na każdym punkcie styku — od logo po obecność w mediach społecznościowych."
      : lang === 'uk'
      ? "Кожен сильний бізнес починається з чіткої ідентичності. Ми будуємо системи брендингу, які працюють на кожній точці контакту — від логотипу до присутності в соціальних мережах."
      : "Every strong business starts with a clear identity. We build brand systems that work across every touchpoint — from your logo to your social media presence.",
    deliverables: lang === 'pl'
      ? ["Logo i identyfikacja wizualna", "Księga znaku", "Wizytówki i materiały", "Szablony social media"]
      : lang === 'uk'
      ? ["Логотип та ідентичність", "Брендбук", "Візитівки та матеріали", "Шаблони соцмереж"]
      : ["Logo & brand identity", "Brand guidelines", "Business cards & stationery", "Social media templates"],
    color: "warm",
  },
  {
    num: '02',
    title: t.services.photoTitle,
    desc: t.services.photoDesc,
    story: lang === 'pl'
      ? "Fotografia produktowa, która sprzedaje. Robimy czyste, przekonujące zdjęcia zaprojektowane pod e-commerce, opakowania i reklamy."
      : lang === 'uk'
      ? "Продуктова фотографія, яка продає. Ми робимо чисті, переконливі знімки для e-commerce, пакування та реклами."
      : "Product photography that sells. We shoot clean, compelling images designed for e-commerce, packaging, and advertising.",
    deliverables: lang === 'pl'
      ? ["Fotografia produktowa", "Zdjęcia lifestyle", "Treści na social media", "Zdjęcia e-commerce"]
      : lang === 'uk'
      ? ["Продуктова фотографія", "Lifestyle зйомка", "Контент для соцмереж", "Фото для e-commerce"]
      : ["Product photography", "Lifestyle shots", "Social media content", "E-commerce imagery"],
    color: "warm",
    link: lang === 'en' ? "/work" : `/${lang}/work`,
  },
  {
    num: '03',
    title: t.services.videoTitle,
    desc: t.services.videoDesc,
    story: lang === 'pl'
      ? "Od filmów brandowych po reelsy — tworzymy treści wideo, które przyciągają uwagę i zamieniają widzów w klientów."
      : lang === 'uk'
      ? "Від бренд-фільмів до рілсів — ми створюємо відеоконтент, який привертає увагу та перетворює глядачів на клієнтів."
      : "From brand films to social reels, we create video content that captures attention and converts viewers into customers.",
    deliverables: lang === 'pl'
      ? ["Filmy brandowe", "Wideo produktowe", "Reelsy social media", "Kampanie reklamowe"]
      : lang === 'uk'
      ? ["Бренд-фільми", "Продуктове відео", "Рілси для соцмереж", "Рекламні кампанії"]
      : ["Brand films", "Product videos", "Social reels", "Ad campaigns"],
    color: "warm",
    link: lang === 'en' ? "/work" : `/${lang}/work`,
  },
  {
    num: '04',
    title: t.services.webTitle,
    desc: t.services.webDesc,
    story: lang === 'pl'
      ? "Strony i aplikacje, które pracują tak ciężko jak Ty. Szybkie, piękne i zbudowane, by zamieniać odwiedzających w klientów."
      : lang === 'uk'
      ? "Сайти та застосунки, які працюють так само старанно, як і ви. Швидкі, красиві та створені для конвертації відвідувачів у клієнтів."
      : "Websites and apps that work as hard as you do. Fast, beautiful, and built to convert visitors into customers.",
    deliverables: lang === 'pl'
      ? ["Projektowanie stron", "Sklepy e-commerce", "Landing pages", "Aplikacje webowe"]
      : lang === 'uk'
      ? ["Дизайн та розробка сайтів", "Інтернет-магазини", "Лендінги", "Веб-застосунки"]
      : ["Website design & development", "E-commerce stores", "Landing pages", "Web applications"],
    color: "warm",
  },
  {
    num: '05',
    title: t.services.marketTitle,
    desc: t.services.marketDesc,
    story: lang === 'pl'
      ? "Strategiczny marketing, który dociera do właściwych ludzi. Pomagamy opowiedzieć Twoją historię tam, gdzie Twoi klienci już szukają."
      : lang === 'uk'
      ? "Стратегічний маркетинг, який досягає правильних людей. Ми допомагаємо розповісти вашу історію там, де ваші клієнти вже шукають."
      : "Strategic marketing that reaches the right people. We help you tell your story where your customers are already looking.",
    deliverables: lang === 'pl'
      ? ["Strategia social media", "Planowanie treści", "Reklama płatna", "Kampanie emailowe"]
      : lang === 'uk'
      ? ["Стратегія соцмереж", "Планування контенту", "Платна реклама", "Email-кампанії"]
      : ["Social media strategy", "Content planning", "Paid advertising", "Email campaigns"],
    color: "warm",
  },
];

const pageTitle = lang === 'pl' ? 'Jak Pomagamy' : lang === 'uk' ? 'Як Ми Допомагаємо' : 'How We Help';
const pageSubtitle = lang === 'pl' 
  ? 'Wszystko, czego Twoja marka potrzebuje, by wyglądać profesjonalnie i konwertować klientów — wszystko z jednego studia.'
  : lang === 'uk'
  ? 'Все, що потрібно вашому бренду, щоб виглядати професійно та конвертувати клієнтів — все з однієї студії.'
  : 'Everything your brand needs to look professional and convert customers — all from one studio.';
const ctaTitle = lang === 'pl' ? 'Gotowy zacząć?' : lang === 'uk' ? 'Готові почати?' : 'Ready to start?';
const ctaDesc = lang === 'pl' 
  ? 'Opowiedz nam o swoim projekcie — odpowiemy z konkretnym planem i stałą ceną.'
  : lang === 'uk'
  ? 'Розкажіть нам про свій проект — ми відповімо з чітким планом та фіксованою ціною.'
  : "Tell us about your project — we'll reply with a clear plan and a fixed price.";
const ctaButton = lang === 'pl' ? 'Zacznij projekt' : lang === 'uk' ? 'Розпочати проект' : 'Start your project';
const getQuote = lang === 'pl' ? 'Zapytaj o wycenę' : lang === 'uk' ? 'Запитати ціну' : 'Get a quote';
const viewPortfolio = lang === 'pl' ? 'Zobacz portfolio' : lang === 'uk' ? 'Переглянути портфоліо' : 'View portfolio';
const homeLink = lang === 'en' ? '/' : `/${lang}/`;
---

<Layout lang={lang} title={`${pageTitle} — Artin Studio`}>
  <Navigation lang={lang} t={t} />
  
  <main class="pt-32 pb-24 bg-cream dark:bg-ink-950 min-h-screen relative overflow-hidden">
    <DotGrid color="#ff7a55" dotSize="1.5px" opacity="0.025" />
    
    <div class="max-w-5xl mx-auto px-6 relative z-10">
      
      <!-- Page header -->
      <div class="mb-20 text-center">
        <span class="inline-block text-warm-600 dark:text-warm-400 text-xs font-bold tracking-[0.2em] uppercase mb-4">{t.nav.services}</span>
        <h1 class="font-display font-extrabold text-ink-950 dark:text-white mb-6 leading-tight" style="font-size:clamp(2.5rem,5vw,4rem)">
          {pageTitle.split(' ').slice(0, -1).join(' ')} <span class="text-brand-500">{pageTitle.split(' ').slice(-1)}</span>
        </h1>
        <p class="text-ink-500 dark:text-ink-400 text-lg max-w-2xl mx-auto leading-relaxed">
          {pageSubtitle}
        </p>
      </div>

      <!-- Services list -->
      <div class="space-y-8">
        {services.map((s, i) => (
          <article class="group relative rounded-3xl bg-warm-50 dark:bg-ink-800 border border-warm-200/60 dark:border-white/6 p-8 md:p-10 shadow-sm hover:shadow-xl transition-all duration-300">
            <div class="flex flex-col md:flex-row gap-8">
              
              <!-- Number & Title -->
              <div class="md:w-1/3">
                <span class="text-2xl font-extrabold tracking-[0.08em] text-warm-600 dark:text-warm-400 mb-3 block">{s.num}</span>
                <h2 class="font-display font-extrabold text-ink-900 dark:text-white text-3xl leading-tight mb-3">{s.title}</h2>
                <p class="text-ink-500 dark:text-ink-400 text-base leading-relaxed">{s.desc}</p>
              </div>

              <!-- Story & Deliverables -->
              <div class="md:w-2/3">
                <p class="text-ink-600 dark:text-ink-300 text-lg leading-relaxed mb-6">{s.story}</p>
                
                <div class="flex flex-wrap gap-2 mb-6">
                  {s.deliverables.map(d => (
                    <span class="px-3 py-1.5 rounded-full bg-warm-100 dark:bg-white/5 text-warm-700 dark:text-warm-300 text-sm font-medium">{d}</span>
                  ))}
                </div>

                <div class="flex gap-4">
                  <a href={`${homeLink}#contact`} class="inline-flex items-center gap-2 text-warm-600 dark:text-warm-400 font-bold text-sm hover:text-brand-500 transition-colors">
                    {getQuote}
                    <ArrowIcon class="w-4 h-4" />
                  </a>
                  {s.link && (
                    <a href={s.link} class="inline-flex items-center gap-2 text-ink-500 dark:text-ink-400 font-medium text-sm hover:text-brand-500 transition-colors">
                      {viewPortfolio}
                      <ArrowIcon class="w-4 h-4" />
                    </a>
                  )}
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- CTA section -->
      <div class="mt-20 text-center">
        <div class="inline-block rounded-3xl bg-ink-950 dark:bg-ink-800 p-10 md:p-14 shadow-xl relative overflow-hidden">
          <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_10%_90%,rgba(255,122,85,0.2),transparent)] pointer-events-none"></div>
          <div class="relative">
            <h3 class="font-display font-extrabold text-white text-3xl md:text-4xl mb-4">{ctaTitle}</h3>
            <p class="text-ink-400 text-lg max-w-md mx-auto mb-8">{ctaDesc}</p>
            <a href={`${homeLink}#contact`} class="inline-flex items-center gap-2 bg-brand-500 hover:bg-brand-400 text-white font-bold px-8 py-4 rounded-full transition-all hover:shadow-lg hover:shadow-brand-500/30">
              {ctaButton}
              <ArrowIcon class="w-5 h-5" />
            </a>
          </div>
        </div>
      </div>

    </div>
  </main>

  <Footer t={t} />
</Layout>
