---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import ArrowIcon from '../../components/ui/ArrowIcon.astro';
import DotGrid from '../../components/ui/DotGrid.astro';
import { languages, defaultLang, getTranslations, type Lang } from '../../i18n/translations';

export function getStaticPaths() {
  // Only generate pages for non-default languages (Polish is at root)
  return Object.keys(languages)
    .filter((lang) => lang !== defaultLang)
    .map((lang) => ({
      params: { lang },
    }));
}

const { lang } = Astro.params as { lang: Lang };
const t = getTranslations(lang);

const services = [
  {
    num: '01',
    title: t.services.brandingTitle,
    desc: t.services.brandingDesc,
    story: lang === 'uk'
      ? "Кожен сильний бізнес починається з чіткої ідентичності. Ми створюємо повні системи брендингу — від логотипу, кольорів і шрифтів до шаблонів для соцмереж. Все узгоджено і готове до використання."
      : "Every strong business starts with a clear identity. We build complete brand systems — from logo, colors and typography to social media templates. Everything consistent and ready to use.",
    deliverables: lang === 'uk'
      ? ["Логотип та ідентичність", "Брендбук", "Візитівки та матеріали", "Шаблони соцмереж"]
      : ["Logo & brand identity", "Brand guidelines", "Business cards & stationery", "Social media templates"],
    color: "warm",
  },
  {
    num: '02',
    title: t.services.webTitle,
    desc: t.services.webDesc,
    story: lang === 'uk'
      ? "Ми проектуємо та розробляємо веб-сайти, інтернет-магазини та мобільні застосунки. Ваш бізнес отримує інструмент, який працює 24/7 — приймає замовлення, бронювання, платежі або демонструє вашу пропозицію."
      : "We design and build websites, online stores, and mobile apps. Your business gets a tool that works 24/7 — taking orders, bookings, payments, or showcasing your offer in the best light.",
    deliverables: lang === 'uk'
      ? ["Корпоративні сайти та лендінги", "Інтернет-магазини", "Мобільні застосунки (iOS/Android)", "Системи бронювання та CRM"]
      : ["Business websites & landing pages", "E-commerce stores", "Mobile apps (iOS/Android)", "Booking systems & CRM"],
    color: "warm",
  },
  {
    num: '03',
    title: t.services.photoTitle,
    desc: t.services.photoDesc,
    story: lang === 'uk'
      ? "Професійні фото продуктів, їжі, інтер'єрів та людей. Кожне фото готове для використання на сайті, в онлайн-магазині, соцмережах чи друкованих матеріалах."
      : "Professional photos of products, food, interiors and people. Every shot is ready to use on your website, online store, social media or print materials.",
    deliverables: lang === 'uk'
      ? ["Продуктова фотографія", "Фото їжі та ресторанів", "Бізнес-портрети", "Контент для соцмереж"]
      : ["Product photography", "Food & restaurant shots", "Business portraits", "Social media content"],
    color: "warm",
  },
  {
    num: '04',
    title: t.services.videoTitle,
    desc: t.services.videoDesc,
    story: lang === 'uk'
      ? "Короткі відео, які привертають увагу та будують довіру. Ідеально для головної сторінки, Instagram, TikTok чи реклами. Показуємо вашу компанію, продукт чи послугу в дії."
      : "Short videos that grab attention and build trust. Perfect for your homepage, Instagram, TikTok or ads. We show your business, product or service in action.",
    deliverables: lang === 'uk'
      ? ["Корпоративні фільми", "Продуктове відео", "Рілси та TikTok", "Відеореклама"]
      : ["Company films", "Product videos", "Reels & TikToks", "Video ads"],
    color: "warm",
  },
  {
    num: '05',
    title: t.services.marketTitle,
    desc: t.services.marketDesc,
    story: lang === 'uk'
      ? "Допомагаємо знайти клієнтів там, де вони вже є — в Google, Facebook, Instagram. Налаштовуємо рекламу, оптимізуємо Google-профіль і плануємо контент, щоб ваш бізнес був помітним."
      : "We help you reach customers where they already are — on Google, Facebook, Instagram. We set up ads, optimize your Google profile and plan content so your business stays visible.",
    deliverables: lang === 'uk'
      ? ["Реклама Google та Meta", "SEO оптимізація", "Google Мій Бізнес", "Стратегія соцмереж"]
      : ["Google & Meta ads", "SEO optimization", "Google My Business", "Social media strategy"],
    color: "warm",
  },
];

const pageTitle = lang === 'uk' ? 'Як Ми Допомагаємо' : 'How We Help';
const pageTitleFull = lang === 'uk'
  ? 'Наші Послуги — Брендинг, Фотографія, Відео, Сайти та Маркетинг'
  : 'Our Services — Branding, Photography, Video, Web & Marketing';
const pageSubtitle = lang === 'uk'
  ? 'Все, що потрібно вашому бренду, щоб виглядати професійно та конвертувати клієнтів — все з однієї студії.'
  : 'Everything your brand needs to look professional and convert customers — all from one studio.';
const ctaTitle = lang === 'uk' ? 'Готові почати?' : 'Ready to start?';
const ctaDesc = lang === 'uk'
  ? 'Розкажіть нам про свій проект — ми відповімо з чітким планом та фіксованою ціною.'
  : "Tell us about your project — we'll reply with a clear plan and a fixed price.";
const ctaButton = lang === 'uk' ? 'Розпочати проект' : 'Start your project';
const getQuote = lang === 'uk' ? 'Запитати ціну' : 'Get a quote';
const viewPortfolio = lang === 'uk' ? 'Переглянути портфоліо' : 'View portfolio';
// This file only generates for non-default languages (en, uk)
const homeLink = `/${lang}/`;
---

<Layout lang={lang} title={`${pageTitleFull} | Artin Studio`}>
  <Navigation lang={lang} t={t} />
  
  <main class="pt-32 pb-24 bg-cream dark:bg-ink-950 min-h-screen relative overflow-hidden">
    <DotGrid color="#ff7a55" dotSize="1.5px" opacity="0.025" />
    
    <div class="max-w-5xl mx-auto px-6 relative z-10">
      
      <!-- Page header -->
      <div class="mb-20 text-center">
        <span class="inline-block text-warm-600 dark:text-warm-400 text-xs font-bold tracking-[0.2em] uppercase mb-4">{t.nav.services}</span>
        <h1 class="font-display font-extrabold text-ink-950 dark:text-white mb-6 leading-tight" style="font-size:clamp(2.5rem,5vw,4rem)">
          {pageTitle.split(' ').slice(0, -1).join(' ')} <span class="text-brand-500">{pageTitle.split(' ').slice(-1)}</span>
        </h1>
        <p class="text-ink-500 dark:text-ink-400 text-lg max-w-2xl mx-auto leading-relaxed">
          {pageSubtitle}
        </p>
      </div>

      <!-- Services list -->
      <div class="space-y-8">
        {services.map((s, i) => (
          <article class="group relative rounded-3xl bg-warm-50 dark:bg-ink-800 border border-warm-200/60 dark:border-white/6 p-8 md:p-10 shadow-sm hover:shadow-xl transition-all duration-300">
            <div class="flex flex-col md:flex-row gap-8">
              
              <!-- Number & Title -->
              <div class="md:w-1/3">
                <span class="text-2xl font-extrabold tracking-[0.08em] text-warm-600 dark:text-warm-400 mb-3 block">{s.num}</span>
                <h2 class="font-display font-extrabold text-ink-900 dark:text-white text-3xl leading-tight mb-3">{s.title}</h2>
                <p class="text-ink-500 dark:text-ink-400 text-base leading-relaxed">{s.desc}</p>
              </div>

              <!-- Story & Deliverables -->
              <div class="md:w-2/3">
                <p class="text-ink-600 dark:text-ink-300 text-lg leading-relaxed mb-6">{s.story}</p>
                
                <div class="flex flex-wrap gap-2 mb-6">
                  {s.deliverables.map(d => (
                    <span class="px-3 py-1.5 rounded-full bg-warm-100 dark:bg-white/5 text-warm-700 dark:text-warm-300 text-sm font-medium">{d}</span>
                  ))}
                </div>

                <div class="flex gap-4">
                  <a href={`${homeLink}#contact`} class="inline-flex items-center gap-2 text-warm-600 dark:text-warm-400 font-bold text-sm hover:text-brand-500 transition-colors">
                    {getQuote}
                    <ArrowIcon class="w-4 h-4" />
                  </a>
                  {s.link && (
                    <a href={s.link} class="inline-flex items-center gap-2 text-ink-500 dark:text-ink-400 font-medium text-sm hover:text-brand-500 transition-colors">
                      {viewPortfolio}
                      <ArrowIcon class="w-4 h-4" />
                    </a>
                  )}
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- CTA section -->
      <div class="mt-20 text-center">
        <div class="inline-block rounded-3xl bg-ink-950 dark:bg-ink-800 p-10 md:p-14 shadow-xl relative overflow-hidden">
          <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_10%_90%,rgba(255,122,85,0.2),transparent)] pointer-events-none"></div>
          <div class="relative">
            <h3 class="font-display font-extrabold text-white text-3xl md:text-4xl mb-4">{ctaTitle}</h3>
            <p class="text-ink-400 text-lg max-w-md mx-auto mb-8">{ctaDesc}</p>
            <a href={`${homeLink}#contact`} class="inline-flex items-center gap-2 bg-brand-500 hover:bg-brand-400 text-white font-bold px-8 py-4 rounded-full transition-all hover:shadow-lg hover:shadow-brand-500/30">
              {ctaButton}
              <ArrowIcon class="w-5 h-5" />
            </a>
          </div>
        </div>
      </div>

    </div>
  </main>

  <Footer t={t} />
</Layout>
