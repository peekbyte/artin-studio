---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import LazyImage from '../../components/LazyImage.astro';
import ArrowIcon from '../../components/ui/ArrowIcon.astro';
import DotGrid from '../../components/ui/DotGrid.astro';
import Lightbox from '../../components/Lightbox.astro';
import { languages, defaultLang, getTranslations, type Lang } from '../../i18n/translations';

export function getStaticPaths() {
  // Only generate pages for non-default languages (Polish is at root)
  return Object.keys(languages)
    .filter((lang) => lang !== defaultLang)
    .map((lang) => ({
      params: { lang },
    }));
}

const { lang } = Astro.params as { lang: Lang };
const t = getTranslations(lang);

// Polish is default (no prefix), others have prefix
const homeLink = lang === 'pl' ? '/' : `/${lang}/`;

// Translations for the page
const pageText = {
  en: {
    ourWork: "Our Work",
    title: "Visual",
    titleAccent: "Stories",
    subtitle: "Real clients, real results. Each story shows how we helped a business grow through branding, photography, video, and digital strategy.",
    theChallenge: "The Challenge",
    whatWeDid: "What We Did",
    results: "Results",
    viewLarger: "View larger",
    ctaKicker: "Your story next?",
    ctaTitle: "Let's create something together",
    ctaDesc: "Tell us about your business — we'll show you how visual storytelling can help you grow.",
    ctaButton: "Start your story",
  },
  pl: {
    ourWork: "Nasze Prace",
    title: "Wizualne",
    titleAccent: "Historie",
    subtitle: "Prawdziwi klienci, prawdziwe wyniki. Każda historia pokazuje, jak pomogliśmy firmie rosnąć dzięki brandingowi, fotografii, wideo i strategii cyfrowej.",
    theChallenge: "Wyzwanie",
    whatWeDid: "Co Zrobiliśmy",
    results: "Rezultaty",
    viewLarger: "Zobacz większe",
    ctaKicker: "Twoja historia następna?",
    ctaTitle: "Stwórzmy coś razem",
    ctaDesc: "Opowiedz nam o swoim biznesie — pokażemy jak wizualne opowieści mogą pomóc Ci rosnąć.",
    ctaButton: "Zacznij swoją historię",
  },
  uk: {
    ourWork: "Наші Роботи",
    title: "Візуальні",
    titleAccent: "Історії",
    subtitle: "Реальні клієнти, реальні результати. Кожна історія показує, як ми допомогли бізнесу зростати через брендинг, фотографію, відео та цифрову стратегію.",
    theChallenge: "Виклик",
    whatWeDid: "Що Ми Зробили",
    results: "Результати",
    viewLarger: "Збільшити",
    ctaKicker: "Ваша історія наступна?",
    ctaTitle: "Давайте створимо щось разом",
    ctaDesc: "Розкажіть нам про свій бізнес — ми покажемо як візуальні історії можуть допомогти вам зростати.",
    ctaButton: "Почніть свою історію",
  },
};

const text = pageText[lang];

// Full page title for SEO
const pageTitleFull = {
  en: "Visual Stories — Client Case Studies & Portfolio | Artin Studio",
  pl: "Wizualne Historie — Portfolio i Case Studies | Artin Studio",
  uk: "Візуальні Історії — Портфоліо та Кейси | Artin Studio",
};

// Client stories with translations
const stories = [
  {
    id: 'bakery',
    client: lang === 'pl' ? "Warszawska Piekarnia" : lang === 'uk' ? "Варшавська Пекарня" : "Warsaw Sourdough Co.",
    headline: lang === 'pl' ? "Z lokalnej piekarni do marki w całym mieście" : lang === 'uk' ? "Від локальної пекарні до міського бренду" : "From local bakery to city-wide brand",
    challenge: lang === 'pl' 
      ? "Mała rodzinna piekarnia z niesamowitymi produktami, ale bez obecności online. Tracili klientów na rzecz sieci z lepszym marketingiem."
      : lang === 'uk'
      ? "Маленька сімейна пекарня з чудовими продуктами, але без присутності онлайн. Вони втрачали клієнтів на користь мереж з кращим маркетингом."
      : "A small family bakery with amazing products but no online presence. They were losing customers to chains with better marketing.",
    solution: lang === 'pl'
      ? "Kompletny rebranding, fotografia produktowa na nową stronę e-commerce, treści na social media i film promocyjny na Instagram."
      : lang === 'uk'
      ? "Повний ребрендинг, продуктова фотографія для нового e-commerce сайту, контент для соцмереж та промо-відео для Instagram."
      : "Complete brand refresh, product photography for their new e-commerce site, social media content, and a promotional video for Instagram.",
    results: lang === 'pl'
      ? ["3x wzrost zamówień online", "12K nowych obserwujących", "Wyróżnienie w lokalnych blogach"]
      : lang === 'uk'
      ? ["3x зростання онлайн-замовлень", "12K нових підписників", "Згадка в місцевих блогах"]
      : ["3x increase in online orders", "12K new Instagram followers", "Featured in local food blogs"],
    services: ["Branding", lang === 'pl' ? "Fotografia" : lang === 'uk' ? "Фотографія" : "Photography", "Video", lang === 'pl' ? "Strona" : lang === 'uk' ? "Сайт" : "Website"],
    images: ["01034900.webp", "11035239.webp"],
    video: false,
    color: "amber",
  },
  {
    id: 'model',
    client: "Anna K.",
    headline: lang === 'pl' ? "Aspirująca modelka, teraz z kontraktem" : lang === 'uk' ? "Початківець модель, тепер підписана" : "Aspiring model, now signed",
    challenge: lang === 'pl'
      ? "Anna chciała zostać modelką, ale nie miała profesjonalnego portfolio. Agencje nie odpowiadały na jej zdjęcia z telefonu."
      : lang === 'uk'
      ? "Анна хотіла стати моделлю, але не мала професійного портфоліо. Агенції не відповідали на її фото з телефону."
      : "Anna wanted to break into modeling but had no professional portfolio. Agencies weren't responding to her phone photos.",
    solution: lang === 'pl'
      ? "Profesjonalna sesja portfolio z różnymi stylizacjami, projekt comp card i krótki showreel wideo."
      : lang === 'uk'
      ? "Професійна портфоліо-зйомка з різними образами, дизайн comp card та короткий відео-ріл."
      : "Professional portfolio shoot with multiple looks, a comp card design, and a short video reel showcasing her range.",
    results: lang === 'pl'
      ? ["Kontrakt z agencją modelek", "3 sesje komercyjne w pierwszy miesiąc", "Profesjonalna comp card"]
      : lang === 'uk'
      ? ["Контракт з модельним агентством", "3 комерційні зйомки в перший місяць", "Професійна comp card"]
      : ["Signed with Warsaw Model Agency", "3 commercial bookings in first month", "Professional comp card"],
    services: [lang === 'pl' ? "Fotografia" : lang === 'uk' ? "Фотографія" : "Photography", "Video", lang === 'pl' ? "Projekt" : lang === 'uk' ? "Дизайн" : "Design"],
    images: ["11045368.webp", "11045382.webp"],
    video: true,
    color: "rose",
  },
  {
    id: 'ecommerce',
    client: "Glow Cosmetics",
    headline: lang === 'pl' ? "Nowa marka kosmetyczna, gotowa do sprzedaży" : lang === 'uk' ? "Новий бренд косметики, готовий продавати" : "New skincare brand, ready to sell",
    challenge: lang === 'pl'
      ? "Start nowej linii kosmetyków bez żadnych materiałów wizualnych. Potrzebowali wszystkiego — od zdjęć produktów po działający sklep."
      : lang === 'uk'
      ? "Запуск нової лінії косметики без жодних візуальних матеріалів. Потрібно було все — від фото продуктів до працюючого магазину."
      : "Launching a new skincare line with no visual assets. Needed everything from product shots to a working online store.",
    solution: lang === 'pl'
      ? "Fotografia produktowa, identyfikacja wizualna, sklep e-commerce z SEO i reklamy wideo na Meta."
      : lang === 'uk'
      ? "Продуктова фотографія, візуальна ідентичність, e-commerce магазин з SEO та відео-реклами для Meta."
      : "Product photography, brand identity, e-commerce website with SEO, and video ads for Meta campaigns.",
    results: lang === 'pl'
      ? ["€15K przychodu w pierwszym kwartale", "2.4% konwersji", "500+ sprzedanych produktów"]
      : lang === 'uk'
      ? ["€15K доходу в перший квартал", "2.4% конверсії", "500+ проданих продуктів"]
      : ["€15K revenue in first quarter", "2.4% conversion rate", "500+ products sold"],
    services: ["Branding", lang === 'pl' ? "Fotografia" : lang === 'uk' ? "Фотографія" : "Photography", lang === 'pl' ? "Strona" : lang === 'uk' ? "Сайт" : "Website", "Marketing"],
    images: ["11045397.webp", "11045406.webp"],
    video: true,
    color: "sky",
  },
  {
    id: 'restaurant',
    client: "Osteria Bella",
    headline: lang === 'pl' ? "Puste stoliki, teraz rezerwacje na weekendy" : lang === 'uk' ? "Порожні столики, тепер бронювання на вихідні" : "Empty tables to weekend waitlists",
    challenge: lang === 'pl'
      ? "Świetna włoska restauracja walcząca o klientów. Stara strona i stockowe zdjęcia nie oddawały jakości jedzenia."
      : lang === 'uk'
      ? "Чудовий італійський ресторан, який бореться за клієнтів. Старий сайт і стокові фото не передавали якості їжі."
      : "A great Italian restaurant struggling to attract customers. Their old website and stock photos weren't doing the food justice.",
    solution: lang === 'pl'
      ? "Fotografia menu, odświeżenie marki, nowa strona, optymalizacja Google Business i film brandingowy."
      : lang === 'uk'
      ? "Фотографія меню, оновлення бренду, новий сайт, оптимізація Google Business та бренд-фільм."
      : "Menu photography, brand refresh, new website, Google Business optimization, and a brand film for social media.",
    results: lang === 'pl'
      ? ["Pełne weekendy", "Ocena 4.8★ w Google", "40% więcej rezerwacji"]
      : lang === 'uk'
      ? ["Повні вихідні", "Рейтинг 4.8★ в Google", "40% більше бронювань"]
      : ["Fully booked weekends", "4.8★ Google rating", "40% more reservations"],
    services: [lang === 'pl' ? "Fotografia" : lang === 'uk' ? "Фотографія" : "Photography", "Video", lang === 'pl' ? "Strona" : lang === 'uk' ? "Сайт" : "Website", "Marketing"],
    images: ["11045319.webp", "11045412.webp"],
    video: true,
    color: "emerald",
  },
];

const colorClasses: Record<string, { bg: string; border: string; accent: string; badge: string }> = {
  amber: {
    bg: "bg-amber-50 dark:bg-ink-800",
    border: "border-amber-200/60 dark:border-amber-500/20",
    accent: "text-amber-600 dark:text-amber-400",
    badge: "bg-amber-100 dark:bg-amber-500/15 text-amber-700 dark:text-amber-300",
  },
  rose: {
    bg: "bg-rose-50 dark:bg-ink-800",
    border: "border-rose-200/60 dark:border-rose-500/20",
    accent: "text-rose-600 dark:text-rose-400",
    badge: "bg-rose-100 dark:bg-rose-500/15 text-rose-700 dark:text-rose-300",
  },
  sky: {
    bg: "bg-sky-50 dark:bg-ink-800",
    border: "border-sky-200/60 dark:border-sky-500/20",
    accent: "text-sky-600 dark:text-sky-400",
    badge: "bg-sky-100 dark:bg-sky-500/15 text-sky-700 dark:text-sky-300",
  },
  emerald: {
    bg: "bg-emerald-50 dark:bg-ink-800",
    border: "border-emerald-200/60 dark:border-emerald-500/20",
    accent: "text-emerald-600 dark:text-emerald-400",
    badge: "bg-emerald-100 dark:bg-emerald-500/15 text-emerald-700 dark:text-emerald-300",
  },
};
---

<Layout lang={lang} title={pageTitleFull[lang]}>
  <Navigation lang={lang} t={t} />
  
  <main class="pt-32 pb-24 bg-cream dark:bg-ink-950 min-h-screen relative overflow-hidden">
    <DotGrid color="#ff7a55" dotSize="1.5px" opacity="0.025" />
    
    <div class="max-w-5xl mx-auto px-6 relative z-10">
      
      <!-- Page header -->
      <div class="mb-20 text-center">
        <span class="inline-block text-warm-600 dark:text-warm-400 text-xs font-bold tracking-[0.2em] uppercase mb-4">{text.ourWork}</span>
        <h1 class="font-display font-extrabold text-ink-950 dark:text-white mb-6 leading-tight" style="font-size:clamp(2.5rem,5vw,4rem)">
          {text.title} <span class="text-brand-500">{text.titleAccent}</span>
        </h1>
        <p class="text-ink-500 dark:text-ink-400 text-lg max-w-2xl mx-auto leading-relaxed">
          {text.subtitle}
        </p>
      </div>

      <!-- Client stories -->
      <div class="space-y-16">
        {stories.map((story, i) => {
          const colors = colorClasses[story.color];
          return (
            <article class={`group relative rounded-3xl ${colors.bg} border ${colors.border} p-8 md:p-10 shadow-sm overflow-hidden`} id={story.id}>
              
              <!-- Story number -->
              <div class="absolute top-6 right-6 md:top-8 md:right-8">
                <span class={`text-6xl md:text-8xl font-extrabold ${colors.accent} opacity-20`}>
                  {String(i + 1).padStart(2, '0')}
                </span>
              </div>

              <!-- Client & headline -->
              <div class="mb-8">
                <span class={`text-xs font-bold tracking-[0.15em] uppercase ${colors.accent} block mb-2`}>{story.client}</span>
                <h2 class="font-display font-extrabold text-ink-900 dark:text-white text-2xl md:text-3xl leading-tight">{story.headline}</h2>
              </div>

              <!-- Two column layout -->
              <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                
                <!-- Left: Story content -->
                <div class="space-y-6">
                  <!-- Challenge -->
                  <div>
                    <h3 class="text-sm font-bold text-ink-400 dark:text-ink-500 uppercase tracking-wider mb-2">{text.theChallenge}</h3>
                    <p class="text-ink-600 dark:text-ink-300 leading-relaxed">{story.challenge}</p>
                  </div>

                  <!-- Solution -->
                  <div>
                    <h3 class="text-sm font-bold text-ink-400 dark:text-ink-500 uppercase tracking-wider mb-2">{text.whatWeDid}</h3>
                    <p class="text-ink-600 dark:text-ink-300 leading-relaxed">{story.solution}</p>
                  </div>

                  <!-- Services used -->
                  <div class="flex flex-wrap gap-2">
                    {story.services.map(service => (
                      <span class={`px-3 py-1.5 rounded-full text-xs font-bold ${colors.badge}`}>{service}</span>
                    ))}
                    {story.video && (
                      <span class="px-3 py-1.5 rounded-full text-xs font-bold bg-ink-100 dark:bg-white/10 text-ink-600 dark:text-ink-300 flex items-center gap-1">
                        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                        Video
                      </span>
                    )}
                  </div>

                  <!-- Results -->
                  <div class="pt-4 border-t border-ink-200/50 dark:border-white/10">
                    <h3 class="text-sm font-bold text-ink-400 dark:text-ink-500 uppercase tracking-wider mb-3">{text.results}</h3>
                    <ul class="space-y-2">
                      {story.results.map(result => (
                        <li class="flex items-center gap-2 text-ink-700 dark:text-ink-200 font-medium">
                          <svg class={`w-4 h-4 ${colors.accent} shrink-0`} fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                          </svg>
                          {result}
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>

                <!-- Right: Images -->
                <div class="space-y-4">
                  {story.images.map((img, imgIndex) => (
                    <div class="relative rounded-2xl overflow-hidden cursor-pointer group/img" data-lightbox={`/images/optimized/${img}`}>
                      <LazyImage 
                        src={`/images/optimized/${img}`} 
                        alt={`${story.client} project`}
                        class="w-full aspect-[4/3] object-cover group-hover/img:scale-105 transition-transform duration-500"
                      />
                      <div class="absolute inset-0 bg-gradient-to-t from-ink-950/40 via-transparent to-transparent opacity-0 group-hover/img:opacity-100 transition-opacity duration-300 flex items-end p-4">
                        <span class="text-white text-sm font-medium">{text.viewLarger}</span>
                      </div>
                    </div>
                  ))}
                </div>

              </div>

            </article>
          );
        })}
      </div>

      <!-- CTA section -->
      <div class="mt-20 text-center">
        <div class="inline-block rounded-3xl bg-ink-950 dark:bg-ink-800 p-10 md:p-14 shadow-xl relative overflow-hidden max-w-2xl">
          <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_10%_90%,rgba(255,122,85,0.2),transparent)] pointer-events-none"></div>
          <div class="relative">
            <span class="text-brand-400 text-xs font-bold tracking-[0.15em] uppercase block mb-3">{text.ctaKicker}</span>
            <h3 class="font-display font-extrabold text-white text-2xl md:text-3xl mb-4">{text.ctaTitle}</h3>
            <p class="text-ink-400 text-base max-w-md mx-auto mb-8">{text.ctaDesc}</p>
            <a href={`${homeLink}#contact`} class="inline-flex items-center gap-2 bg-brand-500 hover:bg-brand-400 text-white font-bold px-8 py-4 rounded-full transition-all hover:shadow-lg hover:shadow-brand-500/30">
              {text.ctaButton}
              <ArrowIcon class="w-5 h-5" />
            </a>
          </div>
        </div>
      </div>

    </div>
  </main>

  <Footer t={t} />
  <Lightbox />
</Layout>

<style>
  [data-lightbox] {
    cursor: zoom-in;
  }
</style>
