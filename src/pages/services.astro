---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import ArrowIcon from '../components/ui/ArrowIcon.astro';
import DotGrid from '../components/ui/DotGrid.astro';
import { getTranslations, type Lang } from '../i18n/translations';

// Root serves Polish (default language)
const lang: Lang = 'pl';
const t = getTranslations(lang);

const services = [
  {
    num: '01',
    title: t.services.brandingTitle,
    desc: t.services.brandingDesc,
    story: "Każdy silny biznes zaczyna się od jasnej tożsamości. Budujemy kompletne systemy brandingowe — od logo, przez kolory i typografię, po szablony do social media. Wszystko spójne i gotowe do użycia.",
    deliverables: ["Logo i identyfikacja wizualna", "Księga znaku", "Wizytówki i materiały", "Szablony social media"],
    color: "warm",
  },
  {
    num: '02',
    title: t.services.webTitle,
    desc: t.services.webDesc,
    story: "Projektujemy i budujemy strony internetowe, sklepy online oraz aplikacje mobilne i webowe. Twoja firma dostaje narzędzie, które działa 24/7 — przyjmuje zamówienia, rezerwacje, płatności lub pokazuje ofertę w najlepszym świetle.",
    deliverables: ["Strony firmowe i landing pages", "Sklepy internetowe", "Aplikacje mobilne (iOS/Android)", "Systemy rezerwacji i CRM"],
    color: "warm",
  },
  {
    num: '03',
    title: t.services.photoTitle,
    desc: t.services.photoDesc,
    story: "Profesjonalne zdjęcia produktów, jedzenia, wnętrz i ludzi. Każde zdjęcie jest gotowe do użycia na stronie, w sklepie online, w social media czy w materiałach drukowanych.",
    deliverables: ["Fotografia produktowa", "Zdjęcia jedzenia i restauracji", "Portrety biznesowe", "Zdjęcia do social media"],
    color: "warm",
  },
  {
    num: '04',
    title: t.services.videoTitle,
    desc: t.services.videoDesc,
    story: "Krótkie filmy, które przyciągają uwagę i budują zaufanie. Idealne na stronę główną, Instagram, TikTok czy reklamy. Pokazujemy Twoją firmę, produkt lub usługę w akcji.",
    deliverables: ["Filmy o firmie", "Wideo produktowe", "Reelsy i TikToki", "Reklamy wideo"],
    color: "warm",
  },
  {
    num: '05',
    title: t.services.marketTitle,
    desc: t.services.marketDesc,
    story: "Pomagamy dotrzeć do klientów tam, gdzie już są — w Google, na Facebooku, Instagramie. Ustawiamy reklamy, optymalizujemy profil Google i planujemy treści, żeby Twoja firma była widoczna.",
    deliverables: ["Reklamy Google i Meta", "Pozycjonowanie SEO", "Google Moja Firma", "Strategia social media"],
    color: "warm",
  },
];
---

<Layout lang={lang} title="Nasze Usługi — Branding, Fotografia, Wideo, Strony i Marketing | Artin Studio">
  <Navigation lang={lang} t={t} />
  
  <main class="pt-32 pb-24 bg-cream dark:bg-ink-950 min-h-screen relative overflow-hidden">
    <DotGrid color="#ff7a55" dotSize="1.5px" opacity="0.025" />
    
    <div class="max-w-5xl mx-auto px-6 relative z-10">
      
      <!-- Page header -->
      <div class="mb-20 text-center">
        <span class="inline-block text-warm-600 dark:text-warm-400 text-xs font-bold tracking-[0.2em] uppercase mb-4">Nasze Usługi</span>
        <h1 class="font-display font-extrabold text-ink-950 dark:text-white mb-6 leading-tight" style="font-size:clamp(2.5rem,5vw,4rem)">
          Jak pomagamy Ci <span class="text-brand-500">rosnąć</span>
        </h1>
        <p class="text-ink-500 dark:text-ink-400 text-lg max-w-2xl mx-auto leading-relaxed">
          Wszystko, czego Twoja marka potrzebuje, by wyglądać profesjonalnie i konwertować klientów — wszystko z jednego studia.
        </p>
      </div>

      <!-- Services list -->
      <div class="space-y-8">
        {services.map((s, i) => (
          <article class="group relative rounded-3xl bg-warm-50 dark:bg-ink-800 border border-warm-200/60 dark:border-white/6 p-8 md:p-10 shadow-sm hover:shadow-xl transition-all duration-300">
            <div class="flex flex-col md:flex-row gap-8">
              
              <!-- Number & Title -->
              <div class="md:w-1/3">
                <span class="text-2xl font-extrabold tracking-[0.08em] text-warm-600 dark:text-warm-400 mb-3 block">{s.num}</span>
                <h2 class="font-display font-extrabold text-ink-900 dark:text-white text-3xl leading-tight mb-3">{s.title}</h2>
                <p class="text-ink-500 dark:text-ink-400 text-base leading-relaxed">{s.desc}</p>
              </div>

              <!-- Story & Deliverables -->
              <div class="md:w-2/3">
                <p class="text-ink-600 dark:text-ink-300 text-lg leading-relaxed mb-6">{s.story}</p>
                
                <div class="flex flex-wrap gap-2 mb-6">
                  {s.deliverables.map(d => (
                    <span class="px-3 py-1.5 rounded-full bg-warm-100 dark:bg-white/5 text-warm-700 dark:text-warm-300 text-sm font-medium">{d}</span>
                  ))}
                </div>

                <div class="flex gap-4">
                  <a href="/#contact" class="inline-flex items-center gap-2 text-warm-600 dark:text-warm-400 font-bold text-sm hover:text-brand-500 transition-colors">
                    Zapytaj o wycenę
                    <ArrowIcon class="w-4 h-4" />
                  </a>
                  {s.link && (
                    <a href={s.link} class="inline-flex items-center gap-2 text-ink-500 dark:text-ink-400 font-medium text-sm hover:text-brand-500 transition-colors">
                      Zobacz portfolio
                      <ArrowIcon class="w-4 h-4" />
                    </a>
                  )}
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- CTA section -->
      <div class="mt-20 text-center">
        <div class="inline-block rounded-3xl bg-ink-950 dark:bg-ink-800 p-10 md:p-14 shadow-xl relative overflow-hidden">
          <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_10%_90%,rgba(255,122,85,0.2),transparent)] pointer-events-none"></div>
          <div class="relative">
            <h3 class="font-display font-extrabold text-white text-3xl md:text-4xl mb-4">Gotowy zacząć?</h3>
            <p class="text-ink-400 text-lg max-w-md mx-auto mb-8">Opowiedz nam o swoim projekcie — odpowiemy z konkretnym planem i stałą ceną.</p>
            <a href="/#contact" class="inline-flex items-center gap-2 bg-brand-500 hover:bg-brand-400 text-white font-bold px-8 py-4 rounded-full transition-all hover:shadow-lg hover:shadow-brand-500/30">
              Zacznij projekt
              <ArrowIcon class="w-5 h-5" />
            </a>
          </div>
        </div>
      </div>

    </div>
  </main>

  <Footer t={t} />
</Layout>
