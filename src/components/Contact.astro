---
import type { Translations } from "../i18n/translations";
import AmbientBlobs from './ui/AmbientBlobs.astro';
import DotGrid from './ui/DotGrid.astro';

interface Props {
  t: Translations;
}

const { t } = Astro.props;

interface SocialLink {
  href: string;
  label: string;
  external?: boolean;
  icon: string;
  color: string;
  bg: string;
  darkBg: string;
}

const socials: SocialLink[] = [
  {
    href: `https://wa.me/48511464587?text=${encodeURIComponent(t.contact.whatsappMessage)}`,
    label: "WhatsApp",
    external: true,
    color: "text-emerald-600 dark:text-emerald-400",
    bg: "bg-emerald-50 hover:bg-emerald-100 border-emerald-200 hover:border-emerald-300",
    darkBg: "dark:bg-emerald-500/10 dark:hover:bg-emerald-500/15 dark:border-emerald-500/20 dark:hover:border-emerald-400/40",
    icon: "M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z",
  },
  {
    href: "#",
    label: t.contact.instagram,
    color: "text-pink-600 dark:text-pink-400",
    bg: "bg-pink-50 hover:bg-pink-100 border-pink-200 hover:border-pink-300",
    darkBg: "dark:bg-pink-500/10 dark:hover:bg-pink-500/15 dark:border-pink-500/20 dark:hover:border-pink-400/40",
    icon: "M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z",
  },
  {
    href: "#",
    label: t.contact.youtube,
    color: "text-red-600 dark:text-red-400",
    bg: "bg-red-50 hover:bg-red-100 border-red-200 hover:border-red-300",
    darkBg: "dark:bg-red-500/10 dark:hover:bg-red-500/15 dark:border-red-500/20 dark:hover:border-red-400/40",
    icon: "M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z",
  },
  {
    href: "https://kit.co/artiiin",
    label: t.contact.myGear,
    external: true,
    color: "text-warm-700 dark:text-warm-400",
    bg: "bg-warm-50 hover:bg-warm-100 border-warm-200 hover:border-warm-300",
    darkBg: "dark:bg-warm-500/10 dark:hover:bg-warm-500/15 dark:border-warm-500/20 dark:hover:border-warm-400/40",
    icon: "M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z",
  },
];
---

<section id="contact" class="py-24 lg:min-h-screen lg:flex lg:items-center bg-ink-950 scroll-mt-24 overflow-hidden relative">

  <!-- Ambient warm glow -->
  <AmbientBlobs blobs={[
    { size: 'w-[700px]', position: 'top-0 left-1/2 -translate-x-1/2', light: 'bg-warm-500/5', dark: 'dark:bg-warm-500/5' },
    { size: 'w-[400px]', position: 'bottom-0 right-0 translate-x-1/3 translate-y-1/3', light: 'bg-brand-500/5', dark: 'dark:bg-brand-500/5' },
  ]} />

  <DotGrid color="#f5a623" size={32} opacity="0.025" />

  <div class="w-full max-w-6xl mx-auto px-6 relative z-10">

    <!-- Retro warm section header (dark variant) -->
    <div class="mb-16 text-center">
      <!-- Floating section label -->
      <div class="inline-flex items-center gap-3 mb-6">
        <div class="w-8 h-px bg-warm-500/50"></div>
        <span class="text-warm-400 text-xs tracking-[0.25em] uppercase font-semibold">{t.contact.getInTouch}</span>
        <div class="w-8 h-px bg-warm-500/50"></div>
      </div>
      <h2 class="font-display font-extrabold text-4xl md:text-6xl text-white leading-tight mb-4">
        {t.contact.title}
      </h2>
      <!-- Warm underline -->
      <div class="flex justify-center mt-5">
        <span class="w-20 h-1 rounded-full bg-gradient-to-r from-warm-500 to-brand-400 animate-pulse-soft"></span>
      </div>
    </div>

    <div class="max-w-2xl mx-auto">

      <!-- Social links — retro pill cards -->
      <div class="flex flex-wrap justify-center gap-3 mb-16">
        {
          socials.map(({ href, label, external, icon, color, bg, darkBg }) => (
            <a
              href={href}
              class:list={[
                "group flex items-center gap-3 px-5 py-3.5 rounded-2xl border font-medium text-sm transition-all duration-200 shadow-sm hover:shadow-md hover:-translate-y-0.5",
                bg, darkBg,
              ]}
              aria-label={label}
              {...(external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
            >
              <svg class:list={["w-5 h-5 shrink-0", color]} fill="currentColor" viewBox="0 0 24 24">
                <path d={icon} />
              </svg>
              <span class:list={["transition-colors", color]}>{label}</span>
            </a>
          ))
        }
      </div>

      <!-- Divider with label -->
      <div class="flex items-center gap-4 mb-10">
        <div class="flex-1 h-px bg-white/8"></div>
        <p class="text-ink-500 text-xs tracking-[0.15em] uppercase shrink-0">{t.contact.orSendMessage}</p>
        <div class="flex-1 h-px bg-white/8"></div>
      </div>

      <!-- Retro styled form -->
      <!-- ⚙️  Replace YOUR_FORM_ID below with your Formspree form ID.
           Create a free form at https://formspree.io → copy the 8-char ID (e.g. "xpwzgkdo").
           That's the only change needed for emails to start landing in your inbox. -->
      <form
        id="contact-form"
        action="https://formspree.io/f/YOUR_FORM_ID"
        method="POST"
        class="space-y-4"
      >
        <!-- Hidden field: selected service chips get written here before submit -->
        <input type="hidden" name="service" id="service-hidden" />
        <!-- Honeypot spam guard (Formspree ignores submissions that fill this) -->
        <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-ink-300 text-xs font-semibold tracking-wider uppercase mb-2">{t.contact.name}</label>
            <input
              type="text"
              name="name"
              required
              placeholder={t.contact.namePlaceholder}
              class="w-full px-4 py-3.5 rounded-2xl bg-white/5 border border-white/10 text-white placeholder-ink-600 focus:outline-none focus:border-warm-500/60 focus:bg-white/8 transition-all text-sm"
            />
          </div>
          <div>
            <label class="block text-ink-300 text-xs font-semibold tracking-wider uppercase mb-2">{t.contact.email}</label>
            <input
              type="email"
              name="email"
              required
              placeholder={t.contact.emailPlaceholder}
              class="w-full px-4 py-3.5 rounded-2xl bg-white/5 border border-white/10 text-white placeholder-ink-600 focus:outline-none focus:border-warm-500/60 focus:bg-white/8 transition-all text-sm"
            />
          </div>
        </div>

        <!-- Service selector -->
        <div>
          <label class="block text-ink-300 text-xs font-semibold tracking-wider uppercase mb-2">{t.contact.whatDoYouNeed}</label>
          <div class="flex flex-wrap gap-2" id="service-chips">
            {[t.contact.serviceBranding, t.contact.servicePhotography, t.contact.serviceVideography, t.contact.serviceWebsite, t.contact.serviceMarketing, t.contact.serviceNotSure].map(s => (
              <button
                type="button"
                data-chip
                class="text-xs font-semibold px-3.5 py-1.5 rounded-full border border-white/12 bg-white/5 text-ink-400 hover:border-warm-500/50 hover:text-warm-400 transition-all duration-150"
              >{s}</button>
            ))}
          </div>
        </div>

        <div>
          <label class="block text-ink-300 text-xs font-semibold tracking-wider uppercase mb-2">{t.contact.message}</label>
          <textarea
            name="message"
            rows="4"
            required
            placeholder={t.contact.messagePlaceholder}
            class="w-full px-4 py-3.5 rounded-2xl bg-white/5 border border-white/10 text-white placeholder-ink-600 focus:outline-none focus:border-warm-500/60 focus:bg-white/8 transition-all resize-none text-sm"
          ></textarea>
        </div>

        <!-- Inline feedback (revealed by JS after submit) -->
        <div id="form-success" style="display:none" class="items-center gap-3 px-5 py-4 rounded-2xl bg-emerald-500/10 border border-emerald-500/30 text-emerald-300 text-sm font-medium" role="status">
          <svg class="w-5 h-5 shrink-0 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
          </svg>
          <span>{t.contact.successMessage}</span>
        </div>
        <div id="form-error" style="display:none" class="items-center gap-3 px-5 py-4 rounded-2xl bg-red-500/10 border border-red-500/30 text-red-300 text-sm font-medium" role="alert">
          <svg class="w-5 h-5 shrink-0 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
          </svg>
          <span>{t.contact.errorMessage}</span>
        </div>

        <!-- Submit button — retro warm pill style -->
        <button
          id="submit-btn"
          type="submit"
          class="group w-full relative overflow-hidden bg-gradient-to-r from-warm-500 to-brand-500 hover:from-warm-400 hover:to-brand-400 text-white font-display font-bold py-4 rounded-2xl transition-all duration-300 hover:shadow-xl hover:shadow-warm-500/20 hover:-translate-y-0.5 tracking-wide text-sm disabled:opacity-60 disabled:pointer-events-none"
        >
          <span id="submit-label" class="relative z-10 flex items-center justify-center gap-2">
            {t.contact.send}
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
            </svg>
          </span>
          <span id="submit-sending" style="display:none" class="relative z-10 items-center justify-center gap-2">
            <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
            </svg>
            {t.contact.sending}
          </span>
        </button>

      </form>
    </div>

  </div>
</section>

<script>
  // ── Service chip toggle ──────────────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('[data-chip]').forEach(chip => {
    chip.addEventListener('click', () => {
      const active = chip.classList.contains('border-warm-500/60');
      chip.classList.toggle('border-warm-500/60', !active);
      chip.classList.toggle('text-warm-400', !active);
      chip.classList.toggle('bg-warm-500/10', !active);
      chip.classList.toggle('border-white/12', active);
      chip.classList.toggle('text-ink-400', active);
      chip.classList.toggle('bg-white/5', active);
    });
  });

  // ── Contact form → Formspree (AJAX) ─────────────────────────────────────────
  const contactForm = document.getElementById('contact-form') as HTMLFormElement | null;
  if (contactForm) {
    contactForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Write selected chips to the hidden field
      const selected = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-chip].border-warm-500\\/60'))
        .map(c => c.textContent?.trim())
        .filter(Boolean)
        .join(', ');
      const serviceHidden = document.getElementById('service-hidden') as HTMLInputElement | null;
      if (serviceHidden) serviceHidden.value = selected || 'Not specified';

      // UI: show spinner, hide old feedback
      const submitBtn    = document.getElementById('submit-btn') as HTMLButtonElement | null;
      const submitLabel  = document.getElementById('submit-label') as HTMLElement | null;
      const submitSending= document.getElementById('submit-sending') as HTMLElement | null;
      const formSuccess  = document.getElementById('form-success') as HTMLElement | null;
      const formError    = document.getElementById('form-error')   as HTMLElement | null;

      if (submitBtn)    submitBtn.disabled = true;
      if (submitLabel)  submitLabel.style.display = 'none';
      if (submitSending) submitSending.style.display = 'flex';
      if (formSuccess)  formSuccess.style.display = 'none';
      if (formError)    formError.style.display = 'none';

      try {
        const response = await fetch(contactForm.action, {
          method: 'POST',
          body: new FormData(contactForm),
          headers: { Accept: 'application/json' },
        });

        if (response.ok) {
          // ✅ Success
          if (formSuccess) formSuccess.style.display = 'flex';
          contactForm.reset();
          document.querySelectorAll<HTMLElement>('[data-chip]').forEach(c => {
            c.classList.remove('border-warm-500/60', 'text-warm-400', 'bg-warm-500/10');
            c.classList.add('border-white/12', 'text-ink-400', 'bg-white/5');
          });
        } else {
          // ❌ Formspree returned an error
          if (formError) formError.style.display = 'flex';
        }
      } catch {
        // ❌ Network error
        if (formError) formError.style.display = 'flex';
      } finally {
        if (submitBtn)    submitBtn.disabled = false;
        if (submitLabel)  submitLabel.style.display = 'flex';
        if (submitSending) submitSending.style.display = 'none';
      }
    });
  }
</script>
