---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="contact" class="py-24 bg-ink-950 scroll-mt-20">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-display font-bold text-white mb-4">{t.contact.title}</h2>
      <p class="text-ink-400 text-lg max-w-xl mx-auto">{t.contact.description}</p>
    </div>
    
    <div class="max-w-4xl mx-auto">
      <!-- Social Links -->
      <div class="flex flex-wrap justify-center gap-4 mb-16">
        <a href="#" class="group flex items-center gap-3 px-6 py-4 rounded-2xl bg-white/5 border border-white/10 hover:bg-brand-500/10 hover:border-brand-400/50 transition-all" aria-label="Instagram">
          <svg class="w-6 h-6 text-brand-400" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
          <span class="text-white font-medium group-hover:text-brand-400 transition">{t.contact.instagram}</span>
        </a>
        <a href="#" class="group flex items-center gap-3 px-6 py-4 rounded-2xl bg-white/5 border border-white/10 hover:bg-brand-500/10 hover:border-brand-400/50 transition-all" aria-label="YouTube">
          <svg class="w-6 h-6 text-brand-400" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
          <span class="text-white font-medium group-hover:text-brand-400 transition">{t.contact.youtube}</span>
        </a>
        <a href="https://kit.co/artiiin" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-3 px-6 py-4 rounded-2xl bg-white/5 border border-white/10 hover:bg-brand-500/10 hover:border-brand-400/50 transition-all" aria-label="Kit">
          <svg class="w-6 h-6 text-brand-400" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
          </svg>
          <span class="text-white font-medium group-hover:text-brand-400 transition">{t.contact.myGear}</span>
        </a>
      </div>

      <!-- Contact Form -->
      <div class="max-w-lg mx-auto">
        <div class="text-center mb-8">
          <p class="text-ink-400">{t.contact.orSendMessage}</p>
        </div>
        <form id="contact-form" class="space-y-4">
          <div>
            <label class="block text-white/80 text-sm font-medium mb-2">{t.contact.name}</label>
            <input type="text" placeholder={t.contact.namePlaceholder} class="w-full px-5 py-4 rounded-2xl bg-white/5 border border-white/10 text-white placeholder-ink-500 focus:outline-none focus:border-brand-400 transition" />
          </div>
          <div>
            <label class="block text-white/80 text-sm font-medium mb-2">{t.contact.email}</label>
            <input type="email" placeholder={t.contact.emailPlaceholder} class="w-full px-5 py-4 rounded-2xl bg-white/5 border border-white/10 text-white placeholder-ink-500 focus:outline-none focus:border-brand-400 transition" />
          </div>
          <div>
            <label class="block text-white/80 text-sm font-medium mb-2">{t.contact.message}</label>
            <textarea rows="4" placeholder={t.contact.messagePlaceholder} class="w-full px-5 py-4 rounded-2xl bg-white/5 border border-white/10 text-white placeholder-ink-500 focus:outline-none focus:border-brand-400 transition resize-none"></textarea>
          </div>
          <button type="submit" class="w-full bg-brand-500 hover:bg-brand-400 text-white font-semibold py-4 rounded-2xl transition-all hover:shadow-lg hover:shadow-brand-500/25">{t.contact.send}</button>
        </form>
      </div>
    </div>
  </div>
</section>
