---
import type { Translations } from "../i18n/translations";

interface Props {
  t: Translations;
}

const { t } = Astro.props;

interface SocialLink {
  href: string;
  label: string;
  external?: boolean;
  icon: string;
  color: string;
  bg: string;
  darkBg: string;
}

const socials: SocialLink[] = [
  {
    href: "#",
    label: t.contact.instagram,
    color: "text-pink-600 dark:text-pink-400",
    bg: "bg-pink-50 hover:bg-pink-100 border-pink-200 hover:border-pink-300",
    darkBg: "dark:bg-pink-500/10 dark:hover:bg-pink-500/15 dark:border-pink-500/20 dark:hover:border-pink-400/40",
    icon: "M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z",
  },
  {
    href: "#",
    label: t.contact.youtube,
    color: "text-red-600 dark:text-red-400",
    bg: "bg-red-50 hover:bg-red-100 border-red-200 hover:border-red-300",
    darkBg: "dark:bg-red-500/10 dark:hover:bg-red-500/15 dark:border-red-500/20 dark:hover:border-red-400/40",
    icon: "M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z",
  },
  {
    href: "https://kit.co/artiiin",
    label: t.contact.myGear,
    external: true,
    color: "text-warm-700 dark:text-warm-400",
    bg: "bg-warm-50 hover:bg-warm-100 border-warm-200 hover:border-warm-300",
    darkBg: "dark:bg-warm-500/10 dark:hover:bg-warm-500/15 dark:border-warm-500/20 dark:hover:border-warm-400/40",
    icon: "M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z",
  },
];
---

<section id="contact" class="py-24 bg-ink-950 scroll-mt-24 overflow-hidden relative">

  <!-- Ambient warm glow in dark -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-[400px] rounded-full bg-warm-500/5 blur-3xl pointer-events-none" aria-hidden="true"></div>
  <div class="absolute bottom-0 right-0 w-[400px] h-[400px] rounded-full bg-brand-500/5 blur-3xl pointer-events-none translate-x-1/3 translate-y-1/3" aria-hidden="true"></div>

  <!-- Retro dot grid -->
  <div
    class="absolute inset-0 pointer-events-none opacity-[0.025]"
    style="background-image: radial-gradient(circle, #f5a623 1px, transparent 1px); background-size: 32px 32px;"
    aria-hidden="true"
  ></div>

  <div class="max-w-6xl mx-auto px-6 relative z-10">

    <!-- Retro warm section header (dark variant) -->
    <div class="mb-16 text-center">
      <!-- Floating section label -->
      <div class="inline-flex items-center gap-3 mb-6">
        <div class="w-8 h-px bg-warm-500/50"></div>
        <span class="text-warm-400 text-xs tracking-[0.25em] uppercase font-semibold">Get in touch</span>
        <div class="w-8 h-px bg-warm-500/50"></div>
      </div>
      <h2 class="font-display font-extrabold text-4xl md:text-6xl text-white leading-tight mb-4">
        {t.contact.title}
      </h2>
      <p class="text-ink-400 text-base max-w-lg mx-auto leading-relaxed">{t.contact.description}</p>
      <!-- Warm underline -->
      <div class="flex justify-center mt-5">
        <span class="w-20 h-1 rounded-full bg-gradient-to-r from-warm-500 to-brand-400 animate-pulse-soft"></span>
      </div>
    </div>

    <div class="max-w-2xl mx-auto">

      <!-- Social links — retro pill cards -->
      <div class="flex flex-wrap justify-center gap-3 mb-16">
        {
          socials.map(({ href, label, external, icon, color, bg, darkBg }) => (
            <a
              href={href}
              class:list={[
                "group flex items-center gap-3 px-5 py-3.5 rounded-2xl border font-medium text-sm transition-all duration-200 shadow-sm hover:shadow-md hover:-translate-y-0.5",
                bg, darkBg,
              ]}
              aria-label={label}
              {...(external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
            >
              <svg class:list={["w-5 h-5 shrink-0", color]} fill="currentColor" viewBox="0 0 24 24">
                <path d={icon} />
              </svg>
              <span class:list={["transition-colors", color]}>{label}</span>
            </a>
          ))
        }
      </div>

      <!-- Divider with label -->
      <div class="flex items-center gap-4 mb-10">
        <div class="flex-1 h-px bg-white/8"></div>
        <p class="text-ink-500 text-xs tracking-[0.15em] uppercase shrink-0">{t.contact.orSendMessage}</p>
        <div class="flex-1 h-px bg-white/8"></div>
      </div>

      <!-- Retro styled form -->
      <form id="contact-form" class="space-y-4">

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-ink-300 text-xs font-semibold tracking-wider uppercase mb-2">{t.contact.name}</label>
            <input
              type="text"
              placeholder={t.contact.namePlaceholder}
              class="w-full px-4 py-3.5 rounded-2xl bg-white/5 border border-white/10 text-white placeholder-ink-600 focus:outline-none focus:border-warm-500/60 focus:bg-white/8 transition-all text-sm"
            />
          </div>
          <div>
            <label class="block text-ink-300 text-xs font-semibold tracking-wider uppercase mb-2">{t.contact.email}</label>
            <input
              type="email"
              placeholder={t.contact.emailPlaceholder}
              class="w-full px-4 py-3.5 rounded-2xl bg-white/5 border border-white/10 text-white placeholder-ink-600 focus:outline-none focus:border-warm-500/60 focus:bg-white/8 transition-all text-sm"
            />
          </div>
        </div>

        <div>
          <label class="block text-ink-300 text-xs font-semibold tracking-wider uppercase mb-2">{t.contact.message}</label>
          <textarea
            rows="5"
            placeholder={t.contact.messagePlaceholder}
            class="w-full px-4 py-3.5 rounded-2xl bg-white/5 border border-white/10 text-white placeholder-ink-600 focus:outline-none focus:border-warm-500/60 focus:bg-white/8 transition-all resize-none text-sm"
          ></textarea>
        </div>

        <!-- Submit button — retro warm pill style -->
        <button
          type="submit"
          class="group w-full relative overflow-hidden bg-gradient-to-r from-warm-500 to-brand-500 hover:from-warm-400 hover:to-brand-400 text-white font-display font-bold py-4 rounded-2xl transition-all duration-300 hover:shadow-xl hover:shadow-warm-500/20 hover:-translate-y-0.5 tracking-wide text-sm"
        >
          <span class="relative z-10 flex items-center justify-center gap-2">
            {t.contact.send}
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
            </svg>
          </span>
        </button>

      </form>
    </div>

  </div>
</section>

<script>
  const contactForm = document.getElementById("contact-form") as HTMLFormElement;
  if (contactForm) {
    contactForm.addEventListener("submit", (e) => {
      e.preventDefault();
      const name = (contactForm.querySelector('input[type="text"]') as HTMLInputElement)?.value || "";
      const email = (contactForm.querySelector('input[type="email"]') as HTMLInputElement)?.value || "";
      alert(`Thanks, ${name}! I'll get back to you at ${email} soon.`);
      contactForm.reset();
    });
  }
</script>
