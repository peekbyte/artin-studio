---
interface Props {
  number: string;
  subtitle: string;
  title: string;
  numberClass?: string;
  titleClass?: string;
  gap?: string;
  marginBottom?: string;
  pb?: string;
}

const {
  number,
  subtitle,
  title,
  numberClass = "text-[4rem] md:text-[6rem] text-white/[0.07]",
  titleClass = "text-3xl md:text-5xl text-white",
  gap = "gap-6",
  marginBottom = "mb-14",
  pb = "pb-2",
} = Astro.props;
---

<div class:list={["flex items-end", gap, marginBottom]}>
  <span
    class:list={[
      "font-display font-extrabold leading-none select-none",
      numberClass,
    ]}>{number}</span
  >
  <div class={pb}>
    <p
      class="text-brand-500 text-xs sm:text-sm tracking-[0.15em] sm:tracking-[0.25em] uppercase font-semibold mb-1"
    >
      {subtitle}
    </p>
    <h2 class:list={["font-display font-bold", titleClass]}>{title}</h2>
  </div>
</div>
