---
import type { Translations } from '../i18n/translations';
import LazyImage from './LazyImage.astro';
import { photos } from '../data/photos';
import SectionHeader from './ui/SectionHeader.astro';
import AmbientBlobs from './ui/AmbientBlobs.astro';
import CtaNudge from './ui/CtaNudge.astro';

interface Props {
  t: Translations;
}

const { t } = Astro.props;

const photoBlobs = [
  { size: 'w-[500px]', position: 'top-0 right-0 -translate-y-1/4 translate-x-1/4', light: 'bg-warm-200/25', dark: 'dark:bg-warm-900/10' },
  { size: 'w-[400px]', position: 'bottom-0 left-0 translate-y-1/4 -translate-x-1/4', light: 'bg-brand-100/30', dark: 'dark:bg-brand-900/10' },
];
---

<section id="photography" class="py-24 bg-cream dark:bg-ink-950 scroll-mt-24 overflow-x-hidden relative">

  <AmbientBlobs blobs={photoBlobs} />

  <div class="max-w-6xl mx-auto px-6 relative z-10">

    <SectionHeader
      emoji="📸"
      kicker={t.photography.kicker}
      title={t.photography.title}
      subtitle={t.photography.sub}
      accent="warm"
    />

    <!-- ── Industry showcase cards ── -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">

      <!-- Bakery -->
      <div class="group relative rounded-3xl overflow-hidden bg-amber-50 dark:bg-ink-800 border border-amber-200/60 dark:border-white/6 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
        <div class="absolute inset-0 bg-gradient-to-br from-amber-100/60 to-orange-50/40 dark:from-amber-900/20 dark:to-transparent pointer-events-none"></div>
        <div class="absolute -top-8 -right-8 w-28 h-28 rounded-full border-2 border-amber-300/30 dark:border-amber-500/15 group-hover:scale-125 transition-transform duration-500 pointer-events-none"></div>
        <!-- Row 1: Kicker (left) + Icon (right) -->
        <div class="relative p-6 pb-4 flex items-center justify-between">
          <span class="text-lg font-extrabold tracking-[0.08em] uppercase text-amber-600 dark:text-amber-400">Bakery</span>
          <div class="w-14 h-14 rounded-2xl bg-amber-400/20 dark:bg-amber-500/15 flex items-center justify-center text-2xl shrink-0 group-hover:scale-110 transition-transform duration-300">🥐</div>
        </div>
        <!-- Title & Description -->
        <div class="relative px-6 pb-4">
          <h3 class="font-display font-extrabold text-ink-900 dark:text-white text-2xl leading-tight mb-2">{t.photography.bakeryTitle}</h3>
          <p class="text-ink-500 dark:text-ink-400 text-base leading-relaxed">{t.photography.bakeryDesc}</p>
        </div>
        <div class="relative px-6 pb-4">
          <div class="grid grid-cols-2 gap-2 rounded-xl overflow-hidden">
            {photos.filter(p => p.category === 'bakery').slice(0, 4).map(p => (
              <div class="aspect-[4/3] overflow-hidden rounded-lg relative">
                <LazyImage src={`/images/optimized/${p.file}`} alt={p.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                <div class="absolute inset-0 bg-gradient-to-br from-amber-500/5 to-orange-500/10 pointer-events-none mix-blend-multiply"></div>
              </div>
            ))}
          </div>
        </div>
        <div class="relative px-6 pb-5">
          <span class="text-xs font-bold tracking-[0.15em] uppercase text-amber-600 dark:text-amber-400">{photos.filter(p => p.category === 'bakery').length} {t.photography.samples}</span>
        </div>
      </div>

      <!-- Food & Drink -->
      <div class="group relative rounded-3xl overflow-hidden bg-rose-50 dark:bg-ink-800 border border-rose-200/60 dark:border-white/6 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
        <div class="absolute inset-0 bg-gradient-to-br from-rose-100/50 to-pink-50/30 dark:from-rose-900/15 dark:to-transparent pointer-events-none"></div>
        <div class="absolute -top-8 -right-8 w-28 h-28 rounded-full border-2 border-rose-300/30 dark:border-rose-500/15 group-hover:scale-125 transition-transform duration-500 pointer-events-none"></div>
        <!-- Row 1: Kicker (left) + Icon (right) -->
        <div class="relative p-6 pb-4 flex items-center justify-between">
          <span class="text-lg font-extrabold tracking-[0.08em] uppercase text-rose-600 dark:text-rose-400">Food</span>
          <div class="w-14 h-14 rounded-2xl bg-rose-400/20 dark:bg-rose-500/15 flex items-center justify-center text-2xl shrink-0 group-hover:scale-110 transition-transform duration-300">🍽️</div>
        </div>
        <!-- Title & Description -->
        <div class="relative px-6 pb-4">
          <h3 class="font-display font-extrabold text-ink-900 dark:text-white text-2xl leading-tight mb-2">{t.photography.foodTitle}</h3>
          <p class="text-ink-500 dark:text-ink-400 text-base leading-relaxed">{t.photography.foodDesc}</p>
        </div>
        <div class="relative px-6 pb-4">
          <div class="grid grid-cols-2 gap-2 rounded-xl overflow-hidden">
            {photos.filter(p => p.category === 'food').slice(0, 4).map(p => (
              <div class="aspect-[4/3] overflow-hidden rounded-lg relative">
                <LazyImage src={`/images/optimized/${p.file}`} alt={p.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                <div class="absolute inset-0 bg-gradient-to-br from-rose-500/5 to-orange-500/8 pointer-events-none mix-blend-multiply"></div>
              </div>
            ))}
          </div>
        </div>
        <div class="relative px-6 pb-5">
          <span class="text-xs font-bold tracking-[0.15em] uppercase text-rose-600 dark:text-rose-400">{photos.filter(p => p.category === 'food').length} {t.photography.samples}</span>
        </div>
      </div>

      <!-- Brand Content -->
      <div class="group relative rounded-3xl overflow-hidden bg-sky-50 dark:bg-ink-800 border border-sky-200/60 dark:border-white/6 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
        <div class="absolute inset-0 bg-gradient-to-br from-sky-100/50 to-blue-50/30 dark:from-sky-900/15 dark:to-transparent pointer-events-none"></div>
        <div class="absolute -top-8 -right-8 w-28 h-28 rounded-full border-2 border-sky-300/30 dark:border-sky-500/15 group-hover:scale-125 transition-transform duration-500 pointer-events-none"></div>
        <!-- Row 1: Kicker (left) + Icon (right) -->
        <div class="relative p-6 pb-4 flex items-center justify-between">
          <span class="text-lg font-extrabold tracking-[0.08em] uppercase text-sky-600 dark:text-sky-400">Brand</span>
          <div class="w-14 h-14 rounded-2xl bg-sky-400/20 dark:bg-sky-500/15 flex items-center justify-center text-2xl shrink-0 group-hover:scale-110 transition-transform duration-300">🎯</div>
        </div>
        <!-- Title & Description -->
        <div class="relative px-6 pb-4">
          <h3 class="font-display font-extrabold text-ink-900 dark:text-white text-2xl leading-tight mb-2">{t.photography.brandTitle}</h3>
          <p class="text-ink-500 dark:text-ink-400 text-base leading-relaxed">{t.photography.brandDesc}</p>
        </div>
        <div class="relative px-6 pb-4">
          <div class="grid grid-cols-2 gap-2 rounded-xl overflow-hidden">
            {photos.filter(p => p.category === 'brand').slice(0, 4).map(p => (
              <div class="aspect-[4/3] overflow-hidden rounded-lg relative">
                <LazyImage src={`/images/optimized/${p.file}`} alt={p.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                <div class="absolute inset-0 bg-gradient-to-br from-sky-500/5 to-brand-500/8 pointer-events-none mix-blend-multiply"></div>
              </div>
            ))}
          </div>
        </div>
        <div class="relative px-6 pb-5">
          <span class="text-xs font-bold tracking-[0.15em] uppercase text-sky-600 dark:text-sky-400">{photos.filter(p => p.category === 'brand').length} {t.photography.samples}</span>
        </div>
      </div>

      <!-- Quiet CTA nudge -->
      <CtaNudge
        kicker={t.photography.ctaKicker}
        title={t.photography.ctaTitle}
        description={t.photography.ctaDesc}
      />
    </div>

  </div>
</section>
