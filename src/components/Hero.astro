---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="home" class="min-h-screen flex items-center justify-center relative overflow-hidden">
  <div class="absolute inset-0 bg-ink-950"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_60%_at_50%_0%,rgba(255,122,85,0.25),transparent)]"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_40%_at_80%_80%,rgba(245,166,35,0.1),transparent)]"></div>
  <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] opacity-60"></div>
  <div class="container mx-auto px-6 relative z-10 text-center">
    <p class="text-brand-400 text-sm font-medium tracking-widest uppercase mb-4 animate-fade-in opacity-0" style="animation-delay: 0.1s; animation-fill-mode: forwards;">{t.hero.subtitle}</p>
    <h1 class="text-4xl sm:text-5xl md:text-7xl font-display font-bold text-white mb-6 animate-fade-up opacity-0" style="animation-delay: 0.2s; animation-fill-mode: forwards; line-height: 1.1;" set:html={t.hero.title}></h1>
    <p class="text-lg md:text-xl text-ink-400 max-w-xl mx-auto mb-10 animate-fade-up opacity-0" style="animation-delay: 0.4s; animation-fill-mode: forwards;">
      {t.hero.description}
    </p>
    <div class="flex flex-wrap justify-center gap-4 animate-fade-up opacity-0" style="animation-delay: 0.5s; animation-fill-mode: forwards;">
      <a href="#photography" class="inline-flex items-center gap-2 bg-brand-500 hover:bg-brand-400 text-white px-8 py-4 rounded-full font-semibold transition-all hover:shadow-lg hover:shadow-brand-500/30">{t.hero.viewPhotography}</a>
      <a href="#videography" class="inline-flex items-center gap-2 border-2 border-white/30 hover:border-brand-400 hover:bg-brand-500/10 text-white px-8 py-4 rounded-full font-semibold transition-all">{t.hero.watchVideos}</a>
    </div>
  </div>
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2">
    <a href="#photography" class="text-brand-400/60 hover:text-brand-400 transition">
      <svg class="w-6 h-6 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </a>
  </div>
</section>
