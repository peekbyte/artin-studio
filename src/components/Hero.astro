---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations;
}

const { t } = Astro.props;

const tickerItems = ['Photography', 'Portraits', 'Products', 'Videography', 'Branding', 'Web & Shops', 'Marketing', 'Stories', 'Warsaw', 'Poland', 'Artin Studio'];
---

<section id="home" class="min-h-screen flex flex-col relative overflow-hidden bg-ink-950">
  <!-- Ambient glow -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_50%_70%_at_15%_50%,rgba(255,122,85,0.12),transparent)] pointer-events-none"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_40%_40%_at_90%_15%,rgba(245,166,35,0.07),transparent)] pointer-events-none"></div>

  <!-- Split layout -->
  <div class="flex-1 flex flex-col lg:flex-row relative z-10 min-h-[calc(100vh-3.5rem)]">

    <!-- Left: editorial text -->
    <div class="w-full lg:w-[58%] flex flex-col justify-center px-8 md:px-14 lg:px-20 xl:px-28 pt-28 pb-12 lg:py-0">

      <!-- Kicker -->
      <div class="flex items-center gap-3 mb-10 animate-fade-in opacity-0" style="animation-delay:.1s;animation-fill-mode:forwards">
        <div class="w-10 h-px bg-brand-400"></div>
        <span class="text-brand-400 text-[0.65rem] tracking-[0.35em] uppercase font-semibold">{t.hero.subtitle}</span>
      </div>

      <!-- Oversized stacked title -->
      <h1
        class="font-display font-extrabold text-white leading-[1.05] mb-8 animate-fade-up opacity-0 hero-title"
        style="font-size:clamp(2.6rem,7.5vw,6.5rem);animation-delay:.2s;animation-fill-mode:forwards;text-shadow:0 2px 40px rgba(0,0,0,0.6)"
        set:html={t.hero.title}
      />

      <p class="text-ink-400 text-base md:text-lg max-w-xs leading-relaxed mb-10 animate-fade-up opacity-0" style="animation-delay:.4s;animation-fill-mode:forwards">
        {t.hero.description}
      </p>

      <div class="flex flex-wrap items-center gap-5 animate-fade-up opacity-0" style="animation-delay:.5s;animation-fill-mode:forwards">
        <a href="#photography" class="group inline-flex items-center gap-3 bg-brand-500 hover:bg-brand-400 text-white px-7 py-3.5 rounded-full font-semibold text-sm tracking-wide transition-all hover:shadow-xl hover:shadow-brand-500/30">
          {t.hero.viewPhotography}
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        <a href="#videography" class="inline-flex items-center text-white/50 hover:text-white text-sm font-medium transition-colors border-b border-white/20 hover:border-white/50 pb-px">
          {t.hero.watchVideos}
        </a>
      </div>
    </div>

    <!-- Right: floating photo collage -->
    <div class="hidden lg:block relative w-[42%] overflow-hidden">
      <div class="absolute left-0 inset-y-0 w-px bg-gradient-to-b from-transparent via-white/8 to-transparent"></div>
      <div class="absolute inset-0 flex items-center justify-center">
        <!-- Photo 1: back left, rotated -->
        <div class="absolute top-[12%] left-[4%] w-44 h-56 rounded-2xl overflow-hidden shadow-[0_24px_60px_rgba(0,0,0,0.65)] rotate-[-7deg] animate-fade-in opacity-0" style="animation-delay:.65s;animation-fill-mode:forwards">
          <img src="/images/optimized/01034900.webp" alt="" class="w-full h-full object-cover" loading="eager" />
        </div>
        <!-- Photo 2: centre main -->
        <div class="absolute w-52 rounded-2xl overflow-hidden shadow-[0_32px_70px_rgba(0,0,0,0.7)] rotate-[4deg] z-10 animate-fade-in opacity-0" style="top:18%;left:30%;height:17rem;animation-delay:.8s;animation-fill-mode:forwards">
          <img src="/images/optimized/11045382.webp" alt="" class="w-full h-full object-cover" loading="eager" />
        </div>
        <!-- Photo 3: bottom -->
        <div class="absolute top-[52%] left-[8%] w-48 h-60 rounded-2xl overflow-hidden shadow-[0_24px_60px_rgba(0,0,0,0.65)] rotate-[5deg] z-20 animate-fade-in opacity-0" style="animation-delay:.95s;animation-fill-mode:forwards">
          <img src="/images/optimized/11045440.webp" alt="" class="w-full h-full object-cover" loading="eager" />
        </div>
        <!-- Availability badge -->
        <div class="absolute bottom-[18%] right-[6%] z-30 bg-ink-900/90 border border-white/10 rounded-full px-4 py-2 flex items-center gap-2 backdrop-blur-sm animate-fade-in opacity-0" style="animation-delay:1.1s;animation-fill-mode:forwards">
          <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
          <span class="text-white/70 text-xs font-medium tracking-wide">Available for projects</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Marquee ticker -->
  <div class="relative z-10 border-t border-white/8 overflow-hidden py-3.5 bg-ink-950/60 backdrop-blur-sm">
    <div class="ticker-track flex whitespace-nowrap">
      {[...Array(4)].map(() => (
        <div class="flex items-center shrink-0">
          {tickerItems.map((item) => (
            <span class="flex items-center">
              <span class="mx-6 w-1 h-1 rounded-full bg-brand-500/40 shrink-0"></span>
              <span class="text-[0.65rem] tracking-[0.25em] uppercase text-white/25 font-medium">{item}</span>
            </span>
          ))}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .hero-line2 {
    color: #ff7a55;
    display: block;
  }
</style>
