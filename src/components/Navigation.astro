---
import LanguageSwitcher from './LanguageSwitcher.astro';
import type { Translations, Lang } from '../i18n/translations';

interface Props {
  lang: Lang;
  t: Translations;
}

const { lang, t } = Astro.props;
---

<nav id="navbar" class="fixed w-full top-0 z-50 transition-all duration-300 bg-transparent">
  <div class="max-w-6xl mx-auto px-6 py-4">
    <div class="flex justify-between items-center">
      <a href="#home" class="nav-logo text-xl font-display font-bold text-white tracking-tight">Artin Studio</a>
      <div class="hidden md:flex items-center gap-8">
        <a href="#home" class="nav-link text-white/90 hover:text-white text-sm font-medium transition">{t.nav.home}</a>
        <a href="#photography" class="nav-link text-white/90 hover:text-white text-sm font-medium transition">{t.nav.photography}</a>
        <a href="#videography" class="nav-link text-white/90 hover:text-white text-sm font-medium transition">{t.nav.videography}</a>
        <a href="#about" class="nav-link text-white/90 hover:text-white text-sm font-medium transition">{t.nav.about}</a>
        <a href="#contact" class="nav-link text-white/90 hover:text-white text-sm font-medium transition">{t.nav.contact}</a>
        <LanguageSwitcher currentLang={lang} />
      </div>
      <div class="flex items-center gap-4 md:hidden">
        <LanguageSwitcher currentLang={lang} />
        <button id="mobile-menu-btn" class="text-white p-2" aria-label="Menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>
    <div id="mobile-menu" class="hidden md:hidden mt-4 pb-4 space-y-2">
      <a href="#home" class="block py-2 text-white/90 hover:text-white text-sm">{t.nav.home}</a>
      <a href="#photography" class="block py-2 text-white/90 hover:text-white text-sm">{t.nav.photography}</a>
      <a href="#videography" class="block py-2 text-white/90 hover:text-white text-sm">{t.nav.videography}</a>
      <a href="#about" class="block py-2 text-white/90 hover:text-white text-sm">{t.nav.about}</a>
      <a href="#contact" class="block py-2 text-white/90 hover:text-white text-sm">{t.nav.contact}</a>
    </div>
  </div>
</nav>
