---
import LanguageSwitcher from './LanguageSwitcher.astro';
import ThemeToggle from './ThemeToggle.astro';
import type { Translations, Lang } from '../i18n/translations';

interface Props {
  lang: Lang;
  t: Translations;
}

const { lang, t } = Astro.props;

const navItems = [
  { href: '#home',        label: t.nav.home },
  { href: '#services',    label: t.nav.services },
  { href: '#photography', label: t.nav.photography },
  { href: '#videography', label: t.nav.videography },
  { href: '#about',       label: t.nav.about },
  { href: '#contact',     label: t.nav.contact },
];
---

<nav id="navbar" class="fixed w-full top-0 z-50 transition-all duration-300 bg-transparent">
  <div class="max-w-6xl mx-auto px-6 py-5">
    <div class="flex justify-between items-center">
      <a href="#home" class="nav-logo flex items-center gap-2 group">
        <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-warm-400 to-brand-500 flex items-center justify-center shadow-md transition-transform group-hover:scale-105 shrink-0">
          <span class="text-white font-display font-extrabold text-xs leading-none">A</span>
        </div>
        <span class="text-white font-display font-bold text-lg tracking-tight">Artin Studio</span>
      </a>
      <div class="hidden md:flex items-center gap-8">
        {navItems.map(({ href, label }) => (
          <a href={href} class="nav-link text-white/90 hover:text-white text-sm font-medium transition">{label}</a>
        ))}
        <ThemeToggle />
        <LanguageSwitcher currentLang={lang} />
      </div>
      <div class="flex items-center gap-3 md:hidden">
        <ThemeToggle />
        <LanguageSwitcher currentLang={lang} />
        <button id="mobile-menu-btn" class="text-white p-2" aria-label="Menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>
    <div id="mobile-menu" class="hidden md:hidden mt-3 pb-2 rounded-2xl bg-white/95 dark:bg-ink-900/95 backdrop-blur-md border border-ink-200/60 dark:border-white/8 shadow-xl overflow-hidden">
      {navItems.map(({ href, label }) => (
        <a href={href} class="flex items-center gap-3 px-4 py-3 text-ink-700 dark:text-ink-200 hover:text-brand-500 dark:hover:text-warm-400 hover:bg-brand-50 dark:hover:bg-white/5 text-sm font-medium transition-colors border-b border-ink-100/60 dark:border-white/5 last:border-0">
          <span class="w-1.5 h-1.5 rounded-full bg-warm-400/50 shrink-0"></span>
          {label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar');
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('.nav-link');

  const lightSectionIds = ['photography', 'videography', 'about'];

  function updateNav() {
    const scrollY = window.scrollY;

    navbar?.classList.toggle('scrolled', scrollY > 40);

    let overLight = false;
    sections.forEach((section) => {
      const el = section as HTMLElement;
      const top = el.offsetTop - 100;
      if (scrollY >= top && scrollY < top + el.offsetHeight && lightSectionIds.includes(section.id)) {
        overLight = true;
      }
    });
    navbar?.classList.toggle('nav-light', overLight);

    let current = '';
    sections.forEach((section) => {
      const el = section as HTMLElement;
      const top = el.offsetTop - 120;
      if (scrollY >= top && scrollY < top + el.offsetHeight) current = section.id;
    });
    navLinks.forEach((link) => {
      link.classList.toggle('text-brand-400', link.getAttribute('href') === `#${current}`);
      link.classList.toggle('font-semibold', link.getAttribute('href') === `#${current}`);
    });
  }

  window.addEventListener('scroll', updateNav, { passive: true });
  window.addEventListener('load', updateNav);

  if (mobileMenuBtn && mobileMenu) {
    mobileMenuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
      mobileMenu.classList.toggle('show');
    });
    mobileMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
        mobileMenu.classList.remove('show');
      });
    });
  }
</script>
