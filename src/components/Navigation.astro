---
import LanguageSwitcher from './LanguageSwitcher.astro';
import ThemeToggle from './ThemeToggle.astro';
import type { Translations, Lang } from '../i18n/translations';

interface Props {
  lang: Lang;
  t: Translations;
}

const { lang, t } = Astro.props;

// Helper to build language-aware paths (Polish is default, no prefix)
const langPrefix = lang === 'pl' ? '' : `/${lang}`;

const navItems = [
  { href: `${langPrefix}/#home`,        label: t.nav.home },
  { href: `${langPrefix}/services`,     label: t.nav.services },
  { href: `${langPrefix}/work`,         label: t.nav.work },
  { href: `${langPrefix}/#about`,       label: t.nav.about },
  { href: `${langPrefix}/#contact`,     label: t.nav.contact },
];
---

<nav id="navbar" class="fixed w-full top-0 z-50 transition-all duration-300 bg-transparent">
  <div class="max-w-6xl mx-auto px-6 py-5">
    <div class="flex justify-between items-center">
      <a href={`${langPrefix}/#home`} class="nav-logo group relative">
        <!-- Background glow effect -->
        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-xl pointer-events-none" style="background: radial-gradient(circle at center, rgba(255, 122, 85, 0.15) 0%, transparent 70%); filter: blur(12px);"></div>
        
        <!-- Logo text with premium styling -->
        <span class="relative font-display font-black text-2xl tracking-tighter transition-all duration-300 flex items-center">
          <span class="logo-a inline-block origin-left relative transition-all duration-300 group-hover:scale-125" style="color: rgb(255, 122, 85);">
            A
          </span><span class="text-white ml-0.5 transition-all duration-300 group-hover:tracking-normal">rtin Studio</span>
        </span>
      </a>
      <div class="hidden md:flex items-center gap-8">
        {navItems.map(({ href, label }) => (
          <a href={href} class="nav-link text-white/90 hover:text-white text-sm font-medium transition">{label}</a>
        ))}
        <ThemeToggle />
        <LanguageSwitcher currentLang={lang} />
      </div>
      <div class="flex items-center gap-3 md:hidden">
        <ThemeToggle />
        <LanguageSwitcher currentLang={lang} />
        <button id="mobile-menu-btn" class="text-white p-2" aria-label="Menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>
    <div id="mobile-menu" class="hidden md:hidden mt-3 pb-2 rounded-2xl bg-white/95 dark:bg-ink-900/95 backdrop-blur-md border border-ink-200/60 dark:border-white/8 shadow-xl overflow-hidden">
      {navItems.map(({ href, label }) => (
        <a href={href} class="flex items-center gap-3 px-4 py-3 text-ink-700 dark:text-ink-200 hover:text-brand-500 dark:hover:text-warm-400 hover:bg-brand-50 dark:hover:bg-white/5 text-sm font-medium transition-colors border-b border-ink-100/60 dark:border-white/5 last:border-0">
          <span class="w-1.5 h-1.5 rounded-full bg-warm-400/50 shrink-0"></span>
          {label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar');
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('.nav-link');

  const lightSectionIds = ['home', 'photography', 'videography', 'about'];

  function updateNav() {
    const scrollY = window.scrollY;

    navbar?.classList.toggle('scrolled', scrollY > 40);

    let overLight = false;
    sections.forEach((section) => {
      const el = section as HTMLElement;
      const top = el.offsetTop - 100;
      if (scrollY >= top && scrollY < top + el.offsetHeight && lightSectionIds.includes(section.id)) {
        overLight = true;
      }
    });
    navbar?.classList.toggle('nav-light', overLight);

    let current = '';
    sections.forEach((section) => {
      const el = section as HTMLElement;
      const top = el.offsetTop - 120;
      if (scrollY >= top && scrollY < top + el.offsetHeight) current = section.id;
    });
    navLinks.forEach((link) => {
      link.classList.toggle('text-brand-400', link.getAttribute('href') === `#${current}`);
      link.classList.toggle('font-semibold', link.getAttribute('href') === `#${current}`);
    });
  }

  window.addEventListener('scroll', updateNav, { passive: true });
  window.addEventListener('load', updateNav);

  if (mobileMenuBtn && mobileMenu) {
    mobileMenuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
      mobileMenu.classList.toggle('show');
    });
    mobileMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
        mobileMenu.classList.remove('show');
      });
    });
  }
</script>

<style>
  @keyframes letterGlow {
    0%, 100% {
      filter: brightness(1);
    }
    50% {
      filter: brightness(1.15);
    }
  }

  @keyframes floatUp {
    0%, 100% {
      transform: translateY(0px) rotateZ(0deg);
    }
    50% {
      transform: translateY(-3px) rotateZ(0.5deg);
    }
  }

  @keyframes shimmerWave {
    0% {
      background-position: -1000px 0;
    }
    100% {
      background-position: 1000px 0;
    }
  }

  @keyframes floatUp {
    0%, 100% {
      transform: translateY(0px) rotateZ(0deg);
    }
    50% {
      transform: translateY(-3px) rotateZ(0.5deg);
    }
  }

  @keyframes bgPulse {
    0%, 100% {
      opacity: 0;
      transform: scale(0.95);
    }
    50% {
      opacity: 0.15;
      transform: scale(1.05);
    }
  }

  :global(.nav-logo) {
    position: relative;
    perspective: 1000px;
  }

  :global(.nav-logo .logo-a) {
    font-weight: 900;
    letter-spacing: -0.04em;
    position: relative;
    display: inline-block;
    font-size: 1.25em;
    font-family: 'Clash Display', system-ui, sans-serif;
  }

  :global(.nav-logo:hover .logo-a) {
    animation: letterGlow 0.6s ease-in-out;
  }

  :global(.nav-logo:hover) {
    animation: floatUp 0.5s ease-out;
  }

  /* Light mode adjustments */
  :global(.nav-light .nav-logo .logo-a) {
    /* Pure orange color preserved - no darkening filters */
  }

  :global(.nav-light .nav-logo) {
    /* Keep text contrast in light mode */
  }

  /* Dark mode enhancements */
  :global(.dark .nav-logo .logo-a) {
    filter: brightness(1.2) drop-shadow(0 2px 8px rgba(0, 0, 0, 0.6));
  }

  :global(.dark .nav-logo) {
    filter: brightness(1.1);
  }

  /* Responsive text sizing */
  @media (max-width: 1024px) {
    :global(.nav-logo span) {
      font-size: 1.125rem;
    }
  }

  @media (max-width: 768px) {
    :global(.nav-logo span) {
      font-size: 1rem;
    }
  }

  /* Reduce motion support */
  @media (prefers-reduced-motion: reduce) {
    :global(.nav-logo .logo-a) {
      animation: none;
      transition: none;
    }

    :global(.nav-logo:hover .logo-a) {
      animation: none;
    }

    :global(.nav-logo:hover) {
      animation: none;
    }

    :global(.nav-logo) {
      transition: none;
    }

    :global(.nav-logo .absolute) {
      animation: none;
    }
  }

  /* High contrast mode support */
  @media (prefers-contrast: more) {
    :global(.nav-logo .logo-a) {
      filter: saturate(1.4) drop-shadow(0 1px 4px rgba(0, 0, 0, 0.4));
    }
  }

  /* Focus states for accessibility */
  :global(.nav-logo:focus-visible) {
    outline: 2px solid rgba(255, 122, 85, 0.5);
    outline-offset: 4px;
    border-radius: 6px;
  }
</style>
