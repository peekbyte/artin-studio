---
import type { Translations } from "../i18n/translations";
import SectionHeader from "./SectionHeader.astro";

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="about" class="scroll-mt-20 overflow-hidden">
  <!-- Stats bar -->
  <div class="bg-ink-950 border-b border-white/5">
    <div class="max-w-6xl mx-auto px-6 py-10">
      <div class="grid grid-cols-4 gap-4 divide-x divide-white/10">
        <div class="text-center">
          <p
            class="font-display font-extrabold text-3xl md:text-4xl text-white"
          >
            4
          </p>
          <p class="text-ink-400 text-xs tracking-widest uppercase mt-1">
            Services
          </p>
        </div>
        <div class="text-center">
          <p
            class="font-display font-extrabold text-3xl md:text-4xl text-brand-400"
          >
            500+
          </p>
          <p class="text-ink-400 text-xs tracking-widest uppercase mt-1">
            Photos taken
          </p>
        </div>
        <div class="text-center">
          <p
            class="font-display font-extrabold text-3xl md:text-4xl text-white"
          >
            2+
          </p>
          <p class="text-ink-400 text-xs tracking-widest uppercase mt-1">
            Years active
          </p>
        </div>
        <div class="text-center">
          <p
            class="font-display font-extrabold text-3xl md:text-4xl text-white"
          >
            PL
          </p>
          <p class="text-ink-400 text-xs tracking-widest uppercase mt-1">
            Based
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Main content -->
  <div class="bg-ink-100 py-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <!-- Text col -->
        <div>
          <SectionHeader
            number="03"
            subtitle="The person behind the lens"
            title={t.about.title}
            numberClass="text-[5rem] text-ink-200"
            titleClass="text-3xl md:text-4xl text-ink-950"
            gap="gap-5"
            marginBottom="mb-10"
            pb="pb-1"
          />

          <blockquote class="border-l-4 border-brand-400 pl-5 mb-8">
            <p
              class="font-display text-lg md:text-xl font-semibold text-ink-600 italic leading-snug"
            >
              &ldquo;The best camera is the one that captures the feeling, not
              just the frame.&rdquo;
            </p>
          </blockquote>

          <div class="text-ink-500 space-y-4 text-[0.95rem] leading-[1.75]">
            <p>{t.about.p1}</p>
            <p>{t.about.p2}</p>
            <p>{t.about.p3}</p>
          </div>

          <a
            href="#contact"
            class="group inline-flex items-center gap-2 mt-8 text-brand-500 hover:text-brand-400 font-semibold text-sm transition-colors"
          >
            Work with me
            <svg
              class="w-4 h-4 transition-transform group-hover:translate-x-1"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>

        <!-- Photo col -->
        <div class="relative">
          <div
            class="absolute -top-4 -right-4 w-full h-full bg-brand-100 rounded-3xl -z-10"
          >
          </div>
          <div
            class="aspect-[4/5] bg-ink-200 rounded-3xl overflow-hidden shadow-xl"
          >
            <img
              src="/images/optimized/11035239.webp"
              alt="Photographer with camera"
              class="w-full h-full object-cover"
            />
          </div>
          <div
            class="absolute -bottom-4 -left-4 bg-ink-950 text-white rounded-2xl px-5 py-3 shadow-xl"
          >
            <p class="font-display font-bold text-sm">Artin Studio</p>
            <p class="text-ink-300 text-xs">Warsaw, Poland &middot; 2024</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
