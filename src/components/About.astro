---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="about" class="py-24 bg-ink-100 scroll-mt-20">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-start">
      <div>
        <h2 class="text-3xl md:text-5xl font-display font-bold text-ink-950 mb-6">{t.about.title}</h2>
        <div class="prose prose-lg text-ink-600 space-y-4">
          <p>{t.about.p1}</p>
          <p>{t.about.p2}</p>
          <p>{t.about.p3}</p>
        </div>
      </div>
      <div class="relative">
        <div class="aspect-[4/5] bg-ink-200 rounded-2xl overflow-hidden flex items-center justify-center">
          <!-- Replace this placeholder with your image: -->
          <!-- <img src="/images/your-photo.jpg" alt="Photographer with camera" class="w-full h-full object-cover" /> -->
          <div class="text-center p-8">
            <svg class="w-16 h-16 mx-auto text-ink-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <p class="text-ink-500 text-sm">{t.about.photoPlaceholder}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
