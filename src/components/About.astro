---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="about" class="py-24 bg-ink-100 scroll-mt-20">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-start">
      <div>
        <h2 class="text-3xl md:text-5xl font-display font-bold text-ink-950 mb-6">{t.about.title}</h2>
        <div class="prose prose-lg text-ink-600 space-y-4">
          <p>{t.about.p1}</p>
          <p>{t.about.p2}</p>
          <p>{t.about.p3}</p>
        </div>
      </div>
      <div class="relative">
        <div class="aspect-[4/5] bg-ink-200 rounded-2xl overflow-hidden">
          <img src="/images/optimized/11035239.webp" alt="Photographer with camera" class="w-full h-full object-cover" />
        </div>
      </div>
    </div>
  </div>
</section>
