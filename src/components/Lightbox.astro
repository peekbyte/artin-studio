---
// Lightbox Modal Component with Storytelling Mode
---

<!-- Lightbox Backdrop -->
<div id="lightbox" class="fixed inset-0 z-[9999] flex items-center justify-center opacity-0 invisible transition-all duration-500 ease-out data-[active]:opacity-100 data-[active]:visible">
  <div class="lightbox-backdrop absolute inset-0 bg-black/95 backdrop-blur-[20px]"></div>
  
  <!-- Cinematic letterbox bars - appear in story mode -->
  <div class="letterbox-top absolute top-0 left-0 right-0 h-0 bg-black z-20 transition-all duration-700 ease-out"></div>
  <div class="letterbox-bottom absolute bottom-0 left-0 right-0 h-0 bg-black z-20 transition-all duration-700 ease-out"></div>
  
  <!-- Ambient particles -->
  <div class="particles absolute inset-0 z-[1] pointer-events-none overflow-hidden opacity-0 transition-opacity duration-1000">
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
  </div>
  
  <!-- Close button -->
  <button class="absolute top-4 right-4 md:top-6 md:right-6 z-30 text-white opacity-70 hover:opacity-100 cursor-pointer bg-transparent border-none p-2 rounded-full transition-all duration-300 hover:rotate-90 hover:bg-white/10" aria-label="Close">
    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
    </svg>
  </button>
  
  <!-- Story toggle button -->
  <button class="story-toggle absolute top-4 left-4 md:top-6 md:left-6 z-30 text-white opacity-70 hover:opacity-100 cursor-pointer bg-white/5 border border-white/20 px-4 py-2 rounded-full transition-all duration-300 hover:bg-orange-500/20 hover:border-orange-500/50 flex items-center gap-2 text-sm font-medium" aria-label="Toggle Story">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
    </svg>
    <span class="story-label">Story</span>
  </button>
  
  <!-- Navigation -->
  <button class="lightbox-nav absolute top-1/2 -translate-y-1/2 left-2 md:left-6 z-30 text-white opacity-0 data-[active]:opacity-60 hover:opacity-100 cursor-pointer bg-white/5 border border-white/10 p-3 md:p-4 rounded-full transition-all duration-300 hover:bg-orange-500/20 hover:border-orange-500/50 hover:scale-110" aria-label="Previous">
    <svg class="w-8 h-8 md:w-10 md:h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
    </svg>
  </button>
  <button class="lightbox-nav absolute top-1/2 -translate-y-1/2 right-2 md:right-6 z-30 text-white opacity-0 data-[active]:opacity-60 hover:opacity-100 cursor-pointer bg-white/5 border border-white/10 p-3 md:p-4 rounded-full transition-all duration-300 hover:bg-orange-500/20 hover:border-orange-500/50 hover:scale-110" aria-label="Next">
    <svg class="w-8 h-8 md:w-10 md:h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
    </svg>
  </button>
  
  <!-- Image container with story overlay -->
  <div class="relative z-10 max-w-[90vw] max-h-[85vh] flex items-center justify-center">
    <img class="lightbox-image max-w-full max-h-[85vh] object-contain rounded-lg shadow-2xl scale-[0.8] translate-y-5 opacity-0 transition-all duration-500 ease-[cubic-bezier(0.34,1.56,0.64,1)] data-[active]:scale-100 data-[active]:translate-y-0 data-[active]:opacity-100 data-[switching]:scale-95 data-[switching]:opacity-50 data-[switching]:duration-200" src="" alt="" />
    
    <!-- Story overlay on image -->
    <div class="story-overlay absolute inset-0 bg-gradient-to-t from-black/90 via-black/30 to-transparent opacity-0 transition-opacity duration-500 pointer-events-none rounded-lg flex flex-col justify-end p-6 md:p-10">
      <div class="story-content translate-y-8 opacity-0 transition-all duration-700 delay-200">
        <h3 class="story-title text-2xl md:text-4xl font-display font-bold text-white mb-3"></h3>
        <p class="story-text text-base md:text-lg text-white/90 leading-relaxed max-w-2xl font-light"></p>
        <div class="story-meta flex items-center gap-4 mt-4 text-sm text-white/60">
          <span class="story-location flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <span></span>
          </span>
          <span class="story-date flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
            <span></span>
          </span>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Counter -->
  <div class="lightbox-counter absolute bottom-8 left-1/2 -translate-x-1/2 z-30 text-white text-sm font-medium opacity-70 flex gap-1 bg-black/50 px-4 py-2 rounded-full backdrop-blur-lg transition-all duration-500">
    <span class="lightbox-current">1</span>
    <span class="opacity-50">/</span>
    <span class="lightbox-total">1</span>
  </div>
  
  <!-- Progress bar -->
  <div class="absolute bottom-0 left-0 right-0 h-[3px] bg-white/10 z-30">
    <div class="lightbox-progress-bar h-full bg-gradient-to-r from-orange-500 to-amber-500 w-0 transition-[width] duration-300"></div>
  </div>
</div>

<style>
  /* Particle animations */
  .particle {
    position: absolute;
    width: 4px;
    height: 4px;
    background: radial-gradient(circle, rgba(255, 165, 100, 0.8) 0%, transparent 70%);
    border-radius: 50%;
    animation: float 15s infinite ease-in-out;
  }
  
  .particle:nth-child(1) { left: 10%; top: 20%; animation-delay: 0s; animation-duration: 12s; }
  .particle:nth-child(2) { left: 30%; top: 60%; animation-delay: 2s; animation-duration: 18s; }
  .particle:nth-child(3) { left: 70%; top: 30%; animation-delay: 4s; animation-duration: 14s; }
  .particle:nth-child(4) { left: 85%; top: 70%; animation-delay: 1s; animation-duration: 16s; }
  .particle:nth-child(5) { left: 50%; top: 85%; animation-delay: 3s; animation-duration: 20s; }
  
  @keyframes float {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.3; }
    25% { transform: translate(30px, -50px) scale(1.5); opacity: 0.8; }
    50% { transform: translate(-20px, -100px) scale(1); opacity: 0.5; }
    75% { transform: translate(40px, -60px) scale(1.2); opacity: 0.7; }
  }
  
  /* Typewriter cursor */
  .story-text::after {
    content: '|';
    animation: blink 1s infinite;
    opacity: 0;
    margin-left: 2px;
  }
  
  .story-text.typing::after {
    opacity: 1;
  }
  
  @keyframes blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }
</style>

<script>
  interface PhotoData {
    src: string;
    title: string;
    story: string;
    location: string;
    date: string;
  }
  
  class Lightbox {
    private lightbox: HTMLElement;
    private image: HTMLImageElement;
    private navButtons: NodeListOf<Element>;
    private currentSpan: HTMLElement;
    private totalSpan: HTMLElement;
    private progressBar: HTMLElement;
    private storyToggle: HTMLElement;
    private storyOverlay: HTMLElement;
    private storyTitle: HTMLElement;
    private storyText: HTMLElement;
    private storyLocation: HTMLElement;
    private storyDate: HTMLElement;
    private storyContent: HTMLElement;
    private letterboxTop: HTMLElement;
    private letterboxBottom: HTMLElement;
    private particles: HTMLElement;
    private counter: HTMLElement;
    private photos: PhotoData[] = [];
    private currentIndex: number = 0;
    private touchStartX: number = 0;
    private touchEndX: number = 0;
    private storyMode: boolean = false;
    private typewriterTimeout: number | null = null;
    
    constructor() {
      this.lightbox = document.getElementById('lightbox')!;
      this.image = this.lightbox.querySelector('.lightbox-image')!;
      this.navButtons = this.lightbox.querySelectorAll('.lightbox-nav');
      this.currentSpan = this.lightbox.querySelector('.lightbox-current')!;
      this.totalSpan = this.lightbox.querySelector('.lightbox-total')!;
      this.progressBar = this.lightbox.querySelector('.lightbox-progress-bar')!;
      this.storyToggle = this.lightbox.querySelector('.story-toggle')!;
      this.storyOverlay = this.lightbox.querySelector('.story-overlay')!;
      this.storyTitle = this.lightbox.querySelector('.story-title')!;
      this.storyText = this.lightbox.querySelector('.story-text')!;
      this.storyLocation = this.lightbox.querySelector('.story-location span')!;
      this.storyDate = this.lightbox.querySelector('.story-date span')!;
      this.storyContent = this.lightbox.querySelector('.story-content')!;
      this.letterboxTop = this.lightbox.querySelector('.letterbox-top')!;
      this.letterboxBottom = this.lightbox.querySelector('.letterbox-bottom')!;
      this.particles = this.lightbox.querySelector('.particles')!;
      this.counter = this.lightbox.querySelector('.lightbox-counter')!;
      
      this.init();
    }
    
    private init() {
      // Collect all gallery images with their data
      const galleryCards = document.querySelectorAll('.photo-card');
      galleryCards.forEach((card) => {
        const cardEl = card as HTMLElement;
        // Read full-size src directly from the data attribute — no string manipulation needed
        const fullSrc = cardEl.dataset.src || '';
        if (!fullSrc) return;

        this.photos.push({
          src: fullSrc,
          title: cardEl.dataset.title || '',
          story: cardEl.dataset.story || '',
          location: cardEl.dataset.location || '',
          date: cardEl.dataset.date || '',
        });

        card.addEventListener('click', () => this.open(this.photos.length - 1));
      });

      this.totalSpan.textContent = String(this.photos.length);
      
      // Event listeners
      this.lightbox.querySelector('[aria-label="Close"]')?.addEventListener('click', () => this.close());
      this.navButtons[0]?.addEventListener('click', () => this.prev());
      this.navButtons[1]?.addEventListener('click', () => this.next());
      this.lightbox.querySelector('.lightbox-backdrop')?.addEventListener('click', () => this.close());
      this.storyToggle.addEventListener('click', () => this.toggleStoryMode());
      
      // Keyboard navigation
      document.addEventListener('keydown', (e) => {
        if (!this.lightbox.hasAttribute('data-active')) return;
        
        switch(e.key) {
          case 'Escape': this.close(); break;
          case 'ArrowLeft': this.prev(); break;
          case 'ArrowRight': this.next(); break;
          case 's': case 'S': this.toggleStoryMode(); break;
        }
      });
      
      // Touch gestures
      this.lightbox.addEventListener('touchstart', (e) => {
        this.touchStartX = e.changedTouches[0].screenX;
      }, { passive: true });
      
      this.lightbox.addEventListener('touchend', (e) => {
        this.touchEndX = e.changedTouches[0].screenX;
        this.handleSwipe();
      }, { passive: true });
      
      // Prevent scroll when open
      this.lightbox.addEventListener('wheel', (e) => e.preventDefault(), { passive: false });
    }
    
    private handleSwipe() {
      const diff = this.touchStartX - this.touchEndX;
      const threshold = 50;
      
      if (diff > threshold) this.next();
      else if (diff < -threshold) this.prev();
    }
    
    /** Resets all story mode UI to its default (hidden) state. */
    private resetStoryUI() {
      this.storyOverlay.style.opacity = '0';
      this.storyContent.style.transform = 'translateY(8px)';
      this.storyContent.style.opacity = '0';
      this.letterboxTop.style.height = '0';
      this.letterboxBottom.style.height = '0';
      this.particles.style.opacity = '0';
      this.counter.style.bottom = '2rem';
      this.storyToggle.querySelector('.story-label')!.textContent = 'Story';
      this.storyToggle.classList.remove('bg-orange-500/30', 'border-orange-500/50');
      this.storyText.classList.remove('typing');
      if (this.typewriterTimeout) {
        clearTimeout(this.typewriterTimeout);
        this.typewriterTimeout = null;
      }
    }

    private toggleStoryMode() {
      this.storyMode = !this.storyMode;
      
      if (this.storyMode) {
        // Enable story mode
        this.storyOverlay.style.opacity = '1';
        this.storyContent.style.transform = 'translateY(0)';
        this.storyContent.style.opacity = '1';
        this.letterboxTop.style.height = '8vh';
        this.letterboxBottom.style.height = '8vh';
        this.particles.style.opacity = '1';
        this.counter.style.bottom = 'calc(8vh + 1rem)';
        this.storyToggle.querySelector('.story-label')!.textContent = 'Hide';
        this.storyToggle.classList.add('bg-orange-500/30', 'border-orange-500/50');
        this.typewriterEffect();
      } else {
        this.resetStoryUI();
      }
    }
    
    private typewriterEffect() {
      const photo = this.photos[this.currentIndex];
      const fullText = photo.story;
      this.storyText.textContent = '';
      this.storyText.classList.add('typing');
      
      let i = 0;
      const speed = 30; // ms per character
      
      const type = () => {
        if (i < fullText.length) {
          this.storyText.textContent += fullText.charAt(i);
          i++;
          this.typewriterTimeout = window.setTimeout(type, speed);
        } else {
          this.storyText.classList.remove('typing');
        }
      };
      
      // Small delay before starting
      this.typewriterTimeout = window.setTimeout(type, 500);
    }
    
    private open(index: number) {
      this.currentIndex = index;
      this.storyMode = false;
      this.resetStoryUI();
      this.updateImage(false);
      this.lightbox.setAttribute('data-active', '');
      this.image.setAttribute('data-active', '');
      this.navButtons.forEach(btn => btn.setAttribute('data-active', ''));
      document.body.style.overflow = 'hidden';
    }
    
    private close() {
      this.lightbox.removeAttribute('data-active');
      this.image.removeAttribute('data-active');
      this.navButtons.forEach(btn => btn.removeAttribute('data-active'));
      document.body.style.overflow = '';
      this.storyMode = false;
      this.resetStoryUI();
    }
    
    private prev() {
      this.currentIndex = (this.currentIndex - 1 + this.photos.length) % this.photos.length;
      this.updateImage(true);
    }
    
    private next() {
      this.currentIndex = (this.currentIndex + 1) % this.photos.length;
      this.updateImage(true);
    }
    
    private updateImage(animate: boolean) {
      if (this.typewriterTimeout) {
        clearTimeout(this.typewriterTimeout);
      }
      
      if (animate) {
        this.image.setAttribute('data-switching', '');
        setTimeout(() => {
          this.setImage();
          this.image.removeAttribute('data-switching');
          if (this.storyMode) {
            this.typewriterEffect();
          }
        }, 200);
      } else {
        this.setImage();
      }
    }
    
    private setImage() {
      const photo = this.photos[this.currentIndex];
      this.image.src = photo.src;
      this.currentSpan.textContent = String(this.currentIndex + 1);
      
      // Update story content
      this.storyTitle.textContent = photo.title;
      this.storyText.textContent = this.storyMode ? '' : photo.story;
      this.storyLocation.textContent = photo.location;
      this.storyDate.textContent = photo.date;
      
      // Update progress bar
      const progress = ((this.currentIndex + 1) / this.photos.length) * 100;
      this.progressBar.style.width = `${progress}%`;
    }
  }
  
  // Initialize when DOM is ready
  document.addEventListener('DOMContentLoaded', () => new Lightbox());
  // Also initialize on Astro page transitions
  document.addEventListener('astro:page-load', () => new Lightbox());
</script>
