---
import type { Translations } from "../i18n/translations";
import SectionHeader from "./SectionHeader.astro";

interface Props {
  t: Translations;
}

const { t } = Astro.props;

const videoPlaceholders = [
  { label: t.videography.video1, caption: t.videography.placeholder },
  { label: t.videography.video2, caption: t.videography.addEmbed },
];
---

<section id="videography" class="py-24 bg-ink-200 scroll-mt-20 overflow-hidden">
  <div class="max-w-6xl mx-auto px-6">
    <!-- Editorial header -->
    <SectionHeader
      number="02"
      subtitle={t.videography.description}
      title={t.videography.title}
      numberClass="text-[4rem] md:text-[6rem] text-ink-300"
      titleClass="text-3xl md:text-5xl text-ink-950"
    />

    <!-- To embed a real video, replace a placeholder div with:
         <div class="video-card rounded-3xl overflow-hidden bg-ink-100 aspect-video">
           <iframe class="w-full h-full" src="https://www.youtube.com/embed/VIDEO_ID" title="..." allowfullscreen></iframe>
         </div> -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      {
        videoPlaceholders.map(({ label, caption }) => (
          <div class="video-card rounded-3xl overflow-hidden bg-ink-100 aspect-video flex items-center justify-center">
            <div class="text-center p-8">
              <svg
                class="w-16 h-16 text-brand-400 mx-auto mb-4"
                fill="currentColor"
                viewBox="0 0 24 24"
              >
                <path d="M8 5v14l11-7z" />
                <path
                  d="M4 3h16a1 1 0 011 1v16a1 1 0 01-1 1H4a1 1 0 01-1-1V4a1 1 0 011-1z"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                />
              </svg>
              <p class="text-ink-800 font-medium">{label}</p>
              <p class="text-ink-600 text-sm mt-1">{caption}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
