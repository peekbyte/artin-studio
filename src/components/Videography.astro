---
import type { Translations } from "../i18n/translations";
import SectionHeader from './ui/SectionHeader.astro';
import AmbientBlobs from './ui/AmbientBlobs.astro';
import DotGrid from './ui/DotGrid.astro';
import CtaNudge from './ui/CtaNudge.astro';

interface Props {
  t: Translations;
}

const { t } = Astro.props;

const industries = [
  {
    id: "brand",
    title: t.videography.brandFilmsTitle,
    desc: t.videography.brandFilmsDesc,
    emoji: "🎬",
    color: "warm",
    uses: t.videography.brandFilmsUses,
    formats: t.videography.brandFilmsFormats,
  },
  {
    id: "product",
    title: t.videography.productTitle,
    desc: t.videography.productDesc,
    emoji: "📦",
    color: "brand",
    uses: t.videography.productUses,
    formats: t.videography.productFormats,
  },
  {
    id: "social",
    title: t.videography.socialTitle,
    desc: t.videography.socialDesc,
    emoji: "📱",
    color: "sky",
    uses: t.videography.socialUses,
    formats: t.videography.socialFormats,
  },
];

const colorMap: Record<string, { bg: string; border: string; grad: string; ring: string; badge: string; dot: string }> = {
  warm:    { bg: "bg-amber-50 dark:bg-ink-800",   border: "border-amber-200/60 dark:border-white/6",   grad: "from-amber-100/60 to-orange-50/40 dark:from-amber-900/20",  ring: "border-amber-300/30 dark:border-amber-500/15",   badge: "text-amber-600 dark:text-amber-400",   dot: "bg-amber-400" },
  brand:   { bg: "bg-brand-50 dark:bg-ink-800",   border: "border-brand-200/60 dark:border-white/6",   grad: "from-brand-100/60 to-orange-50/30 dark:from-brand-900/20",  ring: "border-brand-300/30 dark:border-brand-500/15",   badge: "text-brand-600 dark:text-brand-400",   dot: "bg-brand-400" },
  sky:     { bg: "bg-sky-50 dark:bg-ink-800",     border: "border-sky-200/60 dark:border-white/6",     grad: "from-sky-100/50 to-blue-50/30 dark:from-sky-900/15",         ring: "border-sky-300/30 dark:border-sky-500/15",       badge: "text-sky-600 dark:text-sky-400",       dot: "bg-sky-400" },
};

const videoBlobs = [
  { size: 'w-[450px]', position: 'top-1/4 left-0 -translate-x-1/3', light: 'bg-warm-200/20', dark: 'dark:bg-warm-900/10' },
  { size: 'w-[350px]', position: 'bottom-0 right-0 translate-x-1/3 translate-y-1/3', light: 'bg-brand-200/20', dark: 'dark:bg-brand-900/10' },
];
---

<section id="videography" class="py-24 bg-sand dark:bg-ink-900 scroll-mt-24 overflow-x-hidden relative">

  <AmbientBlobs blobs={videoBlobs} />
  <DotGrid color="#8c520a" opacity="0.03" />

  <div class="max-w-6xl mx-auto px-6 relative z-10">

    <SectionHeader
      emoji="🎬"
      kicker={t.videography.kicker}
      title={t.videography.title}
      subtitle={t.videography.sub}
      accent="brand"
    />

    <!-- ── Industry showcase cards ── -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">

      {industries.map(ind => {
        const c = colorMap[ind.color];
        return (
          <div class:list={["group relative rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1", c.bg, "border", c.border]}>
            <div class:list={["absolute inset-0 bg-gradient-to-br pointer-events-none", c.grad]}></div>
            <div class:list={["absolute -top-8 -right-8 w-28 h-28 rounded-full border-2 group-hover:scale-125 transition-transform duration-500 pointer-events-none", c.ring]}></div>

            <!-- Row 1: Kicker (left) + Icon (right) -->
            <div class="relative p-6 pb-4 flex items-center justify-between">
              <span class:list={["text-lg font-extrabold tracking-[0.08em] uppercase", c.badge]}>{ind.id.toUpperCase()}</span>
              <div class:list={["w-14 h-14 rounded-2xl flex items-center justify-center text-2xl shrink-0 group-hover:scale-110 transition-transform duration-300", `bg-${ind.color === 'warm' ? 'amber' : ind.color === 'brand' ? 'brand' : ind.color}-400/20 dark:bg-${ind.color === 'warm' ? 'amber' : ind.color === 'brand' ? 'brand' : ind.color}-500/15`]}>{ind.emoji}</div>
            </div>

            <!-- Title & Description -->
            <div class="relative px-6 pb-4">
              <h3 class="font-display font-extrabold text-ink-900 dark:text-white text-2xl leading-tight mb-2">{ind.title}</h3>
              <p class="text-ink-500 dark:text-ink-400 text-base leading-relaxed">{ind.desc}</p>
            </div>

            <!-- Use case tags -->
            <div class="relative px-6 pb-4 flex flex-wrap gap-1.5">
              {ind.uses.map(use => (
                <span class="text-[11px] font-semibold px-3 py-1 rounded-full bg-white/70 dark:bg-white/8 text-ink-600 dark:text-ink-300 border border-ink-100/60 dark:border-white/10">{use}</span>
              ))}
            </div>

            <!-- Format row -->
            <div class="relative px-6 pb-5">
              <span class:list={["text-xs font-bold tracking-[0.15em] uppercase", c.badge]}>{ind.formats}</span>
            </div>
          </div>
        );
      })}

      <CtaNudge
        kicker={t.videography.ctaKicker}
        title={t.videography.ctaTitle}
        description={t.videography.ctaDesc}
        kickerColor="text-brand-400"
      />
    </div>

  </div>
</section>
