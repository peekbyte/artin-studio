---
import type { Translations } from '../i18n/translations';

interface Props { t: Translations; }
const { t } = Astro.props;

const steps = [
  {
    num: '01',
    emoji: '💡',
    color: 'violet',
    bg: 'bg-violet-50 dark:bg-violet-950/40',
    border: 'border-violet-200 dark:border-violet-800',
    accent: 'bg-violet-500',
    textAccent: 'text-violet-600 dark:text-violet-400',
    tagBg: 'bg-violet-100 dark:bg-violet-900/50 text-violet-700 dark:text-violet-300',
    title: 'Brand Identity',
    subtitle: 'We start with who you are',
    desc: 'A strong business starts with a clear identity. We design your logo, colour palette, typography and brand guidelines so every touchpoint feels consistent and professional.',
    deliverables: ['Logo design', 'Brand colours', 'Typography', 'Brand guidelines', 'Product labels'],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/>`,
  },
  {
    num: '02',
    emoji: '📸',
    color: 'brand',
    bg: 'bg-orange-50 dark:bg-brand-950/40',
    border: 'border-orange-200 dark:border-brand-800',
    accent: 'bg-brand-500',
    textAccent: 'text-brand-600 dark:text-brand-400',
    tagBg: 'bg-brand-100 dark:bg-brand-900/50 text-brand-700 dark:text-brand-300',
    title: 'Photography & Video',
    subtitle: 'We make your products look irresistible',
    desc: 'Professional product photography, brand portraits and short-form videos that tell your story. Content that stops the scroll and builds trust with your audience.',
    deliverables: ['Product photography', 'Brand portraits', 'Reels & short films', 'Social media content', 'Campaign visuals'],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>`,
  },
  {
    num: '03',
    emoji: '🌐',
    color: 'sky',
    bg: 'bg-sky-50 dark:bg-sky-950/40',
    border: 'border-sky-200 dark:border-sky-800',
    accent: 'bg-sky-500',
    textAccent: 'text-sky-600 dark:text-sky-400',
    tagBg: 'bg-sky-100 dark:bg-sky-900/50 text-sky-700 dark:text-sky-300',
    title: 'Website & Online Shop',
    subtitle: 'We put you on the map — online',
    desc: 'Fast, beautiful websites and online shops built to convert. From a landing page to a full e-commerce store, we make sure your digital home represents your brand perfectly.',
    deliverables: ['Landing pages', 'Business websites', 'Online shops', 'Web applications', 'SEO foundations'],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>`,
  },
  {
    num: '04',
    emoji: '🚀',
    color: 'emerald',
    bg: 'bg-emerald-50 dark:bg-emerald-950/40',
    border: 'border-emerald-200 dark:border-emerald-800',
    accent: 'bg-emerald-500',
    textAccent: 'text-emerald-600 dark:text-emerald-400',
    tagBg: 'bg-emerald-100 dark:bg-emerald-900/50 text-emerald-700 dark:text-emerald-300',
    title: 'Grow & Market',
    subtitle: 'We help you reach more people',
    desc: 'Ongoing content strategy, social media campaigns and marketing that turns your audience into loyal customers. We keep your brand alive and growing long after launch.',
    deliverables: ['Content strategy', 'Social campaigns', 'Email marketing', 'Ad creatives', 'Analytics & growth'],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>`,
  },
];
---

<section id="journey" class="py-28 bg-sand dark:bg-ink-900 scroll-mt-24 overflow-hidden relative">

  <!-- Background decoration -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <svg class="absolute inset-0 w-full h-full opacity-[0.03] dark:opacity-[0.04]" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="dots" width="24" height="24" patternUnits="userSpaceOnUse">
          <circle cx="2" cy="2" r="2" fill="#ff7a55"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#dots)" />
    </svg>
  </div>

  <div class="max-w-6xl mx-auto px-6 relative z-10">

    <!-- Section header -->
    <div class="text-center mb-20">
      <div class="inline-flex items-center gap-2 bg-brand-100 dark:bg-brand-900/40 border border-brand-200 dark:border-brand-800 text-brand-600 dark:text-brand-400 rounded-full px-4 py-1.5 text-xs font-bold tracking-widest uppercase mb-5">
        How we work
      </div>
      <h2 class="font-display font-extrabold text-ink-950 dark:text-white mb-4" style="font-size:clamp(2rem,4.5vw,3.5rem)">
        Your journey from <span class="text-brand-500">idea</span> to <span class="text-warm-500">growing brand</span>
      </h2>
      <p class="text-ink-500 dark:text-ink-400 text-lg max-w-xl mx-auto">
        We walk with you through every step — no jargon, no guesswork, just results.
      </p>
    </div>

    <!-- Steps -->
    <div class="relative">
      <!-- Vertical timeline line -->
      <div class="hidden lg:block absolute left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-transparent via-ink-200 dark:via-ink-700 to-transparent -translate-x-1/2 z-0"></div>

      <div class="space-y-16">
        {steps.map((step, i) => (
          <div class:list={["journey-step relative grid lg:grid-cols-2 gap-8 lg:gap-16 items-center", i % 2 === 1 && "lg:[&>:first-child]:order-2 lg:[&>:last-child]:order-1"]}>

            <!-- Content card -->
            <div class:list={["rounded-3xl border p-8 md:p-10 shadow-sm hover:shadow-lg transition-shadow duration-300", step.bg, step.border]}>
              <!-- Step badge -->
              <div class="flex items-center gap-3 mb-5">
                <span class:list={["w-8 h-8 rounded-full flex items-center justify-center text-white text-xs font-extrabold shrink-0", step.accent]}>{step.num}</span>
                <span class:list={["text-xs font-bold tracking-widest uppercase", step.textAccent]}>{step.subtitle}</span>
              </div>

              <!-- Icon + Title row -->
              <div class="flex items-start gap-4 mb-4">
                <div class:list={["w-12 h-12 rounded-2xl flex items-center justify-center shrink-0", step.tagBg.split(' ').slice(0,2).join(' ')]}>
                  <svg class:list={["w-6 h-6", step.textAccent]} fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={step.icon}/>
                </div>
                <div>
                  <h3 class="font-display font-extrabold text-ink-950 dark:text-white text-xl md:text-2xl leading-tight">{step.title}</h3>
                </div>
              </div>

              <p class="text-ink-600 dark:text-ink-300 text-sm leading-relaxed mb-6">{step.desc}</p>

              <!-- Deliverables -->
              <div class="flex flex-wrap gap-2">
                {step.deliverables.map((d: string) => (
                  <span class:list={["text-xs px-3 py-1 rounded-full font-semibold", step.tagBg]}>{d}</span>
                ))}
              </div>

              <a href="#contact" class:list={["mt-6 inline-flex items-center gap-2 text-sm font-bold transition-colors group", step.textAccent]}>
                Start this step
                <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </a>
            </div>

            <!-- Visual side -->
            <div class="flex flex-col items-center justify-center gap-6">
              <!-- Big emoji in retro badge -->
              <div class="relative">
                <div class:list={["w-32 h-32 rounded-full flex items-center justify-center text-6xl shadow-xl border-4 border-white dark:border-ink-800 animate-float", step.bg]} style={`animation-delay:${i * 0.4}s`}>
                  {step.emoji}
                </div>
                <!-- Timeline node -->
                <div class:list={["absolute top-1/2 -translate-y-1/2 hidden lg:flex items-center justify-center w-5 h-5 rounded-full border-4 border-white dark:border-ink-900 shadow", step.accent,
                  i % 2 === 0 ? "-right-[calc(50%+2.5rem+10px)] lg:left-auto" : "-left-[calc(50%+2.5rem+10px)] lg:right-auto"
                ]}></div>
              </div>

              <!-- Stat chips -->
              <div class="flex gap-3 flex-wrap justify-center">
                <div class="bg-white dark:bg-ink-800 rounded-2xl px-5 py-3 shadow-sm border border-ink-100 dark:border-ink-700 text-center">
                  <p class:list={["font-display font-extrabold text-xl", step.textAccent]}>∞</p>
                  <p class="text-xs text-ink-500 dark:text-ink-400 font-medium">Revisions</p>
                </div>
                <div class="bg-white dark:bg-ink-800 rounded-2xl px-5 py-3 shadow-sm border border-ink-100 dark:border-ink-700 text-center">
                  <p class:list={["font-display font-extrabold text-xl", step.textAccent]}>100%</p>
                  <p class="text-xs text-ink-500 dark:text-ink-400 font-medium">Yours</p>
                </div>
              </div>
            </div>

          </div>
        ))}
      </div>
    </div>

    <!-- Bottom CTA banner -->
    <div class="mt-24 relative rounded-3xl overflow-hidden bg-ink-950 dark:bg-ink-800 p-10 md:p-14 text-center">
      <!-- Glow -->
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_80%_at_50%_50%,rgba(255,122,85,0.18),transparent)] pointer-events-none"></div>
      <div class="relative z-10">
        <p class="text-brand-400 text-sm font-bold tracking-widest uppercase mb-3">Ready to start?</p>
        <h3 class="font-display font-extrabold text-white mb-4" style="font-size:clamp(1.8rem,4vw,3rem)">Let's build your brand together</h3>
        <p class="text-ink-300 max-w-md mx-auto mb-8">Tell us about your business and we'll put together a plan that fits your goals and budget.</p>
        <a href="#contact" class="inline-flex items-center gap-3 bg-brand-500 hover:bg-brand-400 text-white px-8 py-4 rounded-full font-bold text-sm tracking-wide transition-all hover:shadow-2xl hover:shadow-brand-500/40 hover:-translate-y-0.5">
          Start a free conversation
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>

  </div>
</section>

<script>
  // Animate steps on scroll
  const journeySteps = document.querySelectorAll('.journey-step');
  const obs = new IntersectionObserver((entries) => {
    entries.forEach((e, idx) => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).style.animationDelay = `${idx * 0.05}s`;
        e.target.classList.add('step-visible');
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.1 });
  journeySteps.forEach(s => {
    s.classList.add('step-hidden');
    obs.observe(s);
  });
</script>

<style>
  .step-hidden { opacity:0; transform:translateY(32px); transition:opacity 0.6s ease, transform 0.6s ease; }
  .step-visible { opacity:1; transform:translateY(0); }
</style>
