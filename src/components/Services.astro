---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations;
}

const { t } = Astro.props;

// Services ordered as the brand journey: identity → content → digital → growth
const services = [
  {
    num: '01',
    phase: 1,
    key: 'brand',
    title: t.services.brandTitle,
    desc: t.services.brandDesc,
    tags: ['Logo', 'Identity', 'Brand system'],
    accent: 'from-violet-500/20 to-violet-500/5',
    border: 'hover:border-violet-500/60',
    numColor: 'text-violet-500/15',
    tagColor: 'bg-violet-500/10 text-violet-400',
    phaseDot: 'bg-violet-500',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/>`,
    href: '#contact',
  },
  {
    num: '02',
    phase: 2,
    key: 'photo',
    title: t.services.photoTitle,
    desc: t.services.photoDesc,
    tags: ['Product', 'Portrait', 'Brand imagery'],
    accent: 'from-brand-500/20 to-brand-500/5',
    border: 'hover:border-brand-500/60',
    numColor: 'text-brand-500/15',
    tagColor: 'bg-brand-500/10 text-brand-400',
    phaseDot: 'bg-brand-500',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>`,
    href: '#photography',
  },
  {
    num: '03',
    phase: 2,
    key: 'video',
    title: t.services.videoTitle,
    desc: t.services.videoDesc,
    tags: ['Reels', 'Brand films', 'Campaigns'],
    accent: 'from-amber-500/20 to-amber-500/5',
    border: 'hover:border-amber-500/60',
    numColor: 'text-amber-500/15',
    tagColor: 'bg-amber-500/10 text-amber-400',
    phaseDot: 'bg-amber-500',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.723v6.554a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>`,
    href: '#videography',
  },
  {
    num: '04',
    phase: 3,
    key: 'web',
    title: t.services.webTitle,
    desc: t.services.webDesc,
    tags: ['Website', 'Online shop', 'Web app'],
    accent: 'from-sky-500/20 to-sky-500/5',
    border: 'hover:border-sky-500/60',
    numColor: 'text-sky-500/15',
    tagColor: 'bg-sky-500/10 text-sky-400',
    phaseDot: 'bg-sky-500',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>`,
    href: '#contact',
  },
  {
    num: '05',
    phase: 4,
    key: 'market',
    title: t.services.marketTitle,
    desc: t.services.marketDesc,
    tags: ['Strategy', 'Social media', 'Growth'],
    accent: 'from-emerald-500/20 to-emerald-500/5',
    border: 'hover:border-emerald-500/60',
    numColor: 'text-emerald-500/15',
    tagColor: 'bg-emerald-500/10 text-emerald-400',
    phaseDot: 'bg-emerald-500',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>`,
    href: '#contact',
  },
];

// Journey phases — 4 stages that map to the services above
const phases = [
  {
    step: '01',
    label: 'Build Identity',
    caption: 'Define who you are before anything else.',
    services: ['Branding'],
    dotColors: ['bg-violet-500'],
    ringColor: 'ring-violet-500/40',
    borderColor: 'border-violet-500/25',
    textColor: 'text-violet-400',
    bgColor: 'bg-violet-500/5',
  },
  {
    step: '02',
    label: 'Create Content',
    caption: 'Shoot photos and videos that tell your story.',
    services: ['Photography', 'Videography'],
    dotColors: ['bg-brand-500', 'bg-amber-500'],
    ringColor: 'ring-brand-500/40',
    borderColor: 'border-brand-500/25',
    textColor: 'text-brand-400',
    bgColor: 'bg-brand-500/5',
  },
  {
    step: '03',
    label: 'Go Online',
    caption: 'Launch your website, shop or web app.',
    services: ['Web & Digital'],
    dotColors: ['bg-sky-500'],
    ringColor: 'ring-sky-500/40',
    borderColor: 'border-sky-500/25',
    textColor: 'text-sky-400',
    bgColor: 'bg-sky-500/5',
  },
  {
    step: '04',
    label: 'Grow',
    caption: 'Build audience, run campaigns, scale.',
    services: ['Marketing'],
    dotColors: ['bg-emerald-500'],
    ringColor: 'ring-emerald-500/40',
    borderColor: 'border-emerald-500/25',
    textColor: 'text-emerald-400',
    bgColor: 'bg-emerald-500/5',
  },
];
---

<section id="services" class="py-24 bg-ink-950 scroll-mt-20 overflow-hidden">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Section header -->
    <div class="flex items-end gap-6 mb-16">
      <span class="font-display font-extrabold text-[6rem] leading-none text-white/[0.04] select-none">00</span>
      <div class="pb-2">
        <p class="text-brand-500 text-xs tracking-[0.3em] uppercase font-semibold mb-1">{t.services.sectionDesc}</p>
        <h2 class="font-display font-bold text-3xl md:text-5xl text-white">{t.services.sectionTitle}</h2>
      </div>
    </div>

    <!-- ═══ BRAND JOURNEY FLOW ═══ -->
    <div class="mb-20">
      <p class="text-white/25 text-[10px] tracking-[0.4em] uppercase font-semibold mb-8">Your brand journey — step by step</p>

      <!-- Phase nodes + connectors -->
      <div class="relative">
        <!-- Horizontal connector line (desktop only) -->
        <div class="hidden lg:block absolute top-[44px] left-[calc(12.5%)] right-[calc(12.5%)] h-px">
          <div class="w-full h-full bg-gradient-to-r from-violet-500/30 via-brand-500/20 via-sky-500/20 to-emerald-500/30"></div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
          {phases.map((ph, i) => (
            <div class:list={["relative group rounded-2xl border p-5 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg", ph.borderColor, ph.bgColor]}>

              <!-- Step number + dot row -->
              <div class="flex items-center gap-3 mb-4">
                <!-- Pulsing dot(s) -->
                <div class="flex items-center gap-1.5 shrink-0">
                  {ph.dotColors.map((dc) => (
                    <span class:list={["w-2.5 h-2.5 rounded-full ring-2 ring-offset-2 ring-offset-ink-950 transition-all duration-300 group-hover:scale-125", dc, ph.ringColor]}></span>
                  ))}
                </div>
                <!-- Step label -->
                <span class:list={["text-[10px] tracking-[0.3em] uppercase font-bold", ph.textColor]}>{ph.step}</span>
                <!-- Arrow between phases (desktop only, not last) -->
                {i < phases.length - 1 && (
                  <svg class="hidden lg:block absolute -right-[7px] top-[38px] w-3.5 h-3.5 text-white/20 z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
                  </svg>
                )}
              </div>

              <!-- Phase title -->
              <h4 class="font-display font-bold text-white text-base mb-1.5 leading-tight">{ph.label}</h4>
              <p class="text-ink-500 text-xs leading-relaxed mb-3">{ph.caption}</p>

              <!-- Service badges -->
              <div class="flex flex-wrap gap-1.5">
                {ph.services.map((svc, si) => (
                  <span class:list={["text-[10px] px-2.5 py-0.5 rounded-full font-semibold",
                    si === 0 ? `bg-white/6 ${ph.textColor}` : "bg-white/6 text-amber-400"
                  ]}>{svc}</span>
                ))}
              </div>

            </div>
          ))}
        </div>
      </div>

      <!-- Flow summary bar -->
      <div class="mt-4 flex items-center gap-3 text-[11px] text-white/20 font-medium overflow-x-auto pb-1">
        <span class="text-violet-400/50 shrink-0">Branding</span>
        <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-brand-400/50 shrink-0">Photography</span>
        <span class="text-white/10 shrink-0">+</span>
        <span class="text-amber-400/50 shrink-0">Videography</span>
        <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-sky-400/50 shrink-0">Web & Digital</span>
        <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-emerald-400/50 shrink-0">Marketing</span>
        <svg class="w-3 h-3 shrink-0 text-emerald-400/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3l14 9-14 9V3z"/></svg>
        <span class="text-white/15 shrink-0 italic">Your brand, live and growing.</span>
      </div>
    </div>

    <!-- ═══ SERVICE CARDS ═══ -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-4">
      {services.map((s) => (
        <a
          href={s.href}
          class:list={[
            "service-card group relative overflow-hidden rounded-3xl border border-white/8 bg-ink-900 p-8 transition-all duration-500 cursor-pointer",
            "hover:bg-ink-800 hover:shadow-2xl hover:-translate-y-1",
            s.border,
          ]}
        >
          <!-- Ghost number background -->
          <span class:list={["absolute -top-4 -right-2 font-display font-extrabold text-[8rem] leading-none select-none pointer-events-none transition-all duration-500 group-hover:scale-110 group-hover:-translate-y-1", s.numColor]}>
            {s.num}
          </span>

          <!-- Gradient wash on hover -->
          <div class:list={["absolute inset-0 bg-gradient-to-br opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none rounded-3xl", s.accent]}></div>

          <div class="relative z-10">
            <!-- Phase indicator dot + step label -->
            <div class="flex items-center gap-2 mb-5">
              <span class:list={["w-2 h-2 rounded-full", s.phaseDot]}></span>
              <span class="text-[10px] text-white/25 tracking-[0.3em] uppercase font-semibold">Step {s.num}</span>
            </div>

            <!-- Icon -->
            <div class="w-12 h-12 rounded-2xl bg-white/5 border border-white/8 flex items-center justify-center mb-6 group-hover:border-white/15 transition-colors duration-300">
              <svg class="w-6 h-6 text-white/60 group-hover:text-white/90 transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={s.icon} />
            </div>

            <!-- Title -->
            <h3 class="font-display font-bold text-xl text-white mb-3">{s.title}</h3>

            <!-- Description -->
            <p class="text-ink-400 text-sm leading-relaxed mb-6 group-hover:text-ink-300 transition-colors duration-300">{s.desc}</p>

            <!-- Tags -->
            <div class="flex flex-wrap gap-2 mb-6">
              {s.tags.map((tag) => (
                <span class:list={["text-xs px-3 py-1 rounded-full font-medium", s.tagColor]}>{tag}</span>
              ))}
            </div>

            <!-- CTA — slides in on hover -->
            <div class="flex items-center gap-2 text-white/0 group-hover:text-white/70 transition-all duration-300 translate-y-2 group-hover:translate-y-0 text-sm font-medium">
              {t.services.cta}
              <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </div>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>
