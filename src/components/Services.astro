---
import type { Translations } from '../i18n/translations';
import DotGrid from './ui/DotGrid.astro';
import ArrowIcon from './ui/ArrowIcon.astro';

interface Props { t: Translations; }
const { t } = Astro.props;

const services = [
  {
    num: '01', emoji: '🎨',
    title: t.services.brandingTitle,
    desc: t.services.brandingDesc,
    tags: t.services.brandingTags,
    bg:     'bg-violet-50 dark:bg-violet-950/30',
    border: 'border-violet-200/70 dark:border-violet-800/60',
    badge:  'bg-violet-100 dark:bg-violet-900/40 text-violet-700 dark:text-violet-300',
    num_bg: 'bg-violet-500',
    accent: 'text-violet-600 dark:text-violet-400',
  },
  {
    num: '02', emoji: '📸',
    title: t.services.photoTitle,
    desc: t.services.photoDesc,
    tags: t.services.photoTags,
    bg:     'bg-orange-50 dark:bg-brand-950/30',
    border: 'border-orange-200/70 dark:border-brand-800/60',
    badge:  'bg-brand-100 dark:bg-brand-900/40 text-brand-700 dark:text-brand-300',
    num_bg: 'bg-brand-500',
    accent: 'text-brand-600 dark:text-brand-400',
  },
  {
    num: '03', emoji: '🎬',
    title: t.services.videoTitle,
    desc: t.services.videoDesc,
    tags: t.services.videoTags,
    bg:     'bg-amber-50 dark:bg-amber-950/30',
    border: 'border-amber-200/70 dark:border-amber-800/60',
    badge:  'bg-amber-100 dark:bg-amber-900/40 text-amber-700 dark:text-amber-300',
    num_bg: 'bg-amber-500',
    accent: 'text-amber-600 dark:text-amber-400',
  },
  {
    num: '04', emoji: '🌐',
    title: t.services.webTitle,
    desc: t.services.webDesc,
    tags: t.services.webTags,
    bg:     'bg-sky-50 dark:bg-sky-950/30',
    border: 'border-sky-200/70 dark:border-sky-800/60',
    badge:  'bg-sky-100 dark:bg-sky-900/40 text-sky-700 dark:text-sky-300',
    num_bg: 'bg-sky-500',
    accent: 'text-sky-600 dark:text-sky-400',
  },
  {
    num: '05', emoji: '📣',
    title: t.services.marketTitle,
    desc: t.services.marketDesc,
    tags: t.services.marketTags,
    bg:     'bg-emerald-50 dark:bg-emerald-950/30',
    border: 'border-emerald-200/70 dark:border-emerald-800/60',
    badge:  'bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-300',
    num_bg: 'bg-emerald-500',
    accent: 'text-emerald-600 dark:text-emerald-400',
  },
];
---

<section id="journey" class="py-24 bg-sand dark:bg-ink-900 scroll-mt-24 overflow-hidden relative">

  <DotGrid color="#ff7a55" dotSize="1.5px" opacity="0.035" />

  <div class="max-w-6xl mx-auto px-6 relative z-10">

    <!-- Section header -->
    <div class="mb-14">
      <div class="inline-flex items-center gap-2 bg-brand-100 dark:bg-brand-900/40 border border-brand-200 dark:border-brand-800 text-brand-600 dark:text-brand-400 rounded-full px-4 py-1.5 text-xs font-bold tracking-widest uppercase mb-5">
        {t.services.sectionBadge}
      </div>
      <h2 class="font-display font-extrabold text-ink-950 dark:text-white mb-4 leading-tight" style="font-size:clamp(2rem,4.5vw,3.4rem)">
        {t.services.sectionHeading} <span class="text-brand-500">{t.services.sectionHeadingAccent}</span>
      </h2>
      <p class="text-ink-500 dark:text-ink-400 text-lg max-w-2xl leading-relaxed">
        {t.services.sectionSubtext}
      </p>
    </div>

    <!-- Service cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-10">

      {services.map((s, i) => (
        <div class:list={["service-card group relative rounded-3xl border p-6 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1 opacity-0", s.bg, s.border]}>
          <!-- Row 1: Step number (left) + Emoji icon (right) -->
          <div class="flex items-center justify-between mb-5">
            <span class:list={["text-xl font-extrabold tracking-[0.08em] uppercase", s.accent]}>{s.num}</span>
            <div class:list={["w-14 h-14 rounded-2xl flex items-center justify-center text-2xl shrink-0 group-hover:scale-110 transition-transform duration-300", s.badge]}>{s.emoji}</div>
          </div>
          <!-- Title -->
          <h3 class="font-display font-extrabold text-ink-900 dark:text-white text-2xl leading-tight mb-3">{s.title}</h3>
          <!-- Description -->
          <p class="text-ink-500 dark:text-ink-400 text-base leading-relaxed mb-5">{s.desc}</p>
          <!-- Tags -->
          <div class="flex flex-wrap gap-1.5 mb-4">
            {s.tags.map((tag: string) => (
              <span class:list={["text-[11px] font-semibold px-3 py-1 rounded-full", s.badge]}>{tag}</span>
            ))}
          </div>
          <a href="#contact" class:list={["inline-flex items-center gap-1.5 text-sm font-bold opacity-0 group-hover:opacity-100 transition-opacity duration-200", s.accent]}>
            Get a quote
            <ArrowIcon class="w-3.5 h-3.5" />
          </a>
        </div>
      ))}

      <!-- CTA card -->
      <div class="service-card relative rounded-3xl overflow-hidden bg-ink-950 dark:bg-ink-800 p-6 flex flex-col justify-between shadow-md min-h-[260px] opacity-0">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_10%_90%,rgba(255,122,85,0.2),transparent)] pointer-events-none"></div>
        <div class="absolute -top-8 -right-8 w-28 h-28 rounded-full bg-brand-500/10 pointer-events-none"></div>
        <div class="relative">
          <p class="text-brand-400 text-xs font-extrabold tracking-[0.15em] uppercase mb-3">{t.services.ctaKicker}</p>
          <h3 class="font-display font-extrabold text-white text-2xl leading-tight mb-4">{t.services.ctaTitle}</h3>
          <p class="text-ink-400 text-base leading-relaxed">{t.services.ctaDesc}</p>
        </div>
        <a href="#contact" class="relative mt-6 inline-flex items-center gap-2 bg-brand-500 hover:bg-brand-400 text-white font-bold text-sm px-6 py-3 rounded-full transition-all hover:shadow-lg hover:shadow-brand-500/30 self-start">
          {t.services.ctaButton}
          <ArrowIcon class="w-4 h-4" />
        </a>
      </div>

    </div>

  </div>
</section>

<script>
  const cards = document.querySelectorAll<HTMLElement>('.service-card');

  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        const el = e.target as HTMLElement;
        el.style.transition = `opacity 0.5s ease ${el.dataset.delay ?? '0s'}, transform 0.5s cubic-bezier(0.16,1,0.3,1) ${el.dataset.delay ?? '0s'}`;
        el.style.opacity = '1';
        el.style.transform = 'translateY(0)';
        obs.unobserve(el);
      }
    });
  }, { threshold: 0.08 });

  cards.forEach((card, i) => {
    card.style.transform = 'translateY(20px)';
    card.dataset.delay = `${i * 0.07}s`;
    obs.observe(card);
  });
</script>
