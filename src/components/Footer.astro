---
import type { Translations } from "../i18n/translations";

interface Props {
  t: Translations;
}

const { t } = Astro.props;

const services = ["Photography", "Videography", "Branding", "Web & Shops", "Marketing"];
const quickLinks = [
  { href: "#home",        label: "Home" },
  { href: "#services",    label: "Services" },
  { href: "#photography", label: "Photography" },
  { href: "#about",       label: "About" },
  { href: "#contact",     label: "Contact" },
];
---

<footer class="bg-ink-950 relative overflow-hidden">

  <!-- Warm retro ambient glow -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[300px] rounded-full bg-warm-500/4 blur-3xl pointer-events-none" aria-hidden="true"></div>

  <!-- Retro dot grid -->
  <div
    class="absolute inset-0 pointer-events-none opacity-[0.02]"
    style="background-image: radial-gradient(circle, #f5a623 1px, transparent 1px); background-size: 36px 36px;"
    aria-hidden="true"
  ></div>

  <!-- Top border with warm gradient -->
  <div class="h-px w-full bg-gradient-to-r from-transparent via-warm-500/30 to-transparent"></div>

  <!-- Main footer content -->
  <div class="max-w-6xl mx-auto px-6 pt-14 pb-10 relative z-10">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8 mb-12">

      <!-- Brand column -->
      <div class="lg:col-span-2">
        <!-- Wordmark -->
        <a href="#home" class="inline-flex items-center gap-2.5 mb-4 group">
          <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-warm-400 to-brand-500 flex items-center justify-center shadow-lg shadow-warm-500/20 transition-transform group-hover:scale-105">
            <span class="text-white font-display font-extrabold text-base leading-none">A</span>
          </div>
          <span class="font-display font-extrabold text-xl text-white tracking-tight">Artin Studio</span>
        </a>

        <p class="text-ink-500 text-sm leading-relaxed max-w-xs mb-6">
          Creative branding studio. Photography, video, web &amp; identity — everything your business needs to grow.
        </p>

        <!-- Social dots -->
        <div class="flex items-center gap-3">
          <a href="#" aria-label="Instagram"
            class="w-9 h-9 rounded-xl bg-white/5 hover:bg-pink-500/20 border border-white/8 hover:border-pink-500/30 flex items-center justify-center text-ink-400 hover:text-pink-400 transition-all duration-200">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
          <a href="#" aria-label="YouTube"
            class="w-9 h-9 rounded-xl bg-white/5 hover:bg-red-500/20 border border-white/8 hover:border-red-500/30 flex items-center justify-center text-ink-400 hover:text-red-400 transition-all duration-200">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        </div>
      </div>

      <!-- Services column -->
      <div>
        <p class="text-warm-400 text-[10px] font-bold tracking-[0.2em] uppercase mb-5">Services</p>
        <ul class="space-y-2.5">
          {services.map(s => (
            <li>
              <a href="#services" class="text-ink-500 hover:text-warm-400 text-sm transition-colors flex items-center gap-1.5 group">
                <span class="w-1 h-1 rounded-full bg-warm-500/40 group-hover:bg-warm-400 transition-colors shrink-0"></span>
                {s}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Quick links column -->
      <div>
        <p class="text-brand-400 text-[10px] font-bold tracking-[0.2em] uppercase mb-5">Quick links</p>
        <ul class="space-y-2.5">
          {quickLinks.map(({ href, label }) => (
            <li>
              <a href={href} class="text-ink-500 hover:text-brand-400 text-sm transition-colors flex items-center gap-1.5 group">
                <span class="w-1 h-1 rounded-full bg-brand-500/40 group-hover:bg-brand-400 transition-colors shrink-0"></span>
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

    </div>
  </div>

  <!-- Large ghost wordmark -->
  <div class="border-t border-white/5 overflow-hidden pt-6 pb-0 select-none" aria-hidden="true">
    <p
      class="font-display font-extrabold whitespace-nowrap text-center leading-none tracking-tighter text-white/[0.035]"
      style="font-size:clamp(3.5rem,13vw,10rem)"
    >
      ARTIN STUDIO
    </p>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/5">
    <div class="max-w-6xl mx-auto px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-ink-600 text-xs">
      <p>{t.footer.copyright}</p>
      <p>
        {t.footer.designedBy}
        <a
          href="https://parstech.pl"
          target="_blank"
          rel="noopener"
          class="text-warm-500 hover:text-warm-400 transition-colors ml-1 font-medium"
        >parstech.pl</a>
      </p>
    </div>
  </div>

</footer>
