---
import type { Translations } from "../i18n/translations";
import DotGrid from './ui/DotGrid.astro';

interface Props {
  t: Translations;
}

const { t } = Astro.props;

const services = [
  { label: t.services.brandingTitle, href: "#journey" },
  { label: t.nav.photography,         href: "#photography" },
  { label: t.nav.videography,         href: "#videography" },
  { label: t.services.webTitle,  href: "#journey" },
  { label: t.services.marketTitle,  href: "#journey" },
];
const quickLinks = [
  { href: "#home",        label: t.nav.home },
  { href: "#journey",     label: t.nav.services },
  { href: "#photography", label: t.nav.photography },
  { href: "#about",       label: t.nav.about },
  { href: "#contact",     label: t.nav.contact },
];
---

<footer class="bg-ink-950 relative overflow-hidden">

  <!-- Warm retro ambient glow -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[300px] rounded-full bg-warm-500/4 blur-3xl pointer-events-none" aria-hidden="true"></div>

  <DotGrid color="#f5a623" size={36} opacity="0.02" />

  <!-- Top border with warm gradient -->
  <div class="h-px w-full bg-gradient-to-r from-transparent via-warm-500/30 to-transparent"></div>

  <!-- Main footer content -->
  <div class="max-w-6xl mx-auto px-6 pt-14 pb-10 relative z-10">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-10 max-w-md sm:max-w-none sm:mx-auto sm:justify-items-center">

      <!-- Services column -->
      <div>
        <p class="text-warm-400 text-[10px] font-bold tracking-[0.2em] uppercase mb-5">{t.footer.servicesLabel}</p>
        <ul class="space-y-2.5">
          {services.map(s => (
            <li>
              <a href={s.href} class="text-ink-500 hover:text-warm-400 text-sm transition-colors flex items-center gap-1.5 group">
                <span class="w-1 h-1 rounded-full bg-warm-500/40 group-hover:bg-warm-400 transition-colors shrink-0"></span>
                {s.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Quick links column -->
      <div>
        <p class="text-brand-400 text-[10px] font-bold tracking-[0.2em] uppercase mb-5">{t.footer.quickLinksLabel}</p>
        <ul class="space-y-2.5">
          {quickLinks.map(({ href, label }) => (
            <li>
              <a href={href} class="text-ink-500 hover:text-brand-400 text-sm transition-colors flex items-center gap-1.5 group">
                <span class="w-1 h-1 rounded-full bg-brand-500/40 group-hover:bg-brand-400 transition-colors shrink-0"></span>
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

    </div>
  </div>

  <!-- Large ghost wordmark -->
  <div class="border-t border-white/5 overflow-hidden pt-6 pb-0 select-none" aria-hidden="true">
    <p
      class="font-display font-extrabold whitespace-nowrap text-center leading-none tracking-tighter text-white/[0.035]"
      style="font-size:clamp(3.5rem,13vw,10rem)"
    >
      ARTIN STUDIO
    </p>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/5">
    <div class="max-w-6xl mx-auto px-6 py-5 flex items-center justify-center text-ink-600 text-xs">
      <p>{t.footer.copyright}</p>
    </div>
  </div>

</footer>
