---
import type { Lang } from '../i18n/translations';

interface Props {
  title?: string;
  lang?: Lang;
}

const { title = "Artin Studio — Photography & Videography", lang = 'en' } = Astro.props;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Clash+Display:wght@400;500;600;700&family=Inter:wght@100;200;300;400;500;600;700;800;900&family=Crimson+Text:ital,wght@0,400;0,600;1,400&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Syne:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="font-sans bg-cream dark:bg-ink-950 text-ink-900 dark:text-ink-100 antialiased transition-colors duration-300">
    <slot />
  </body>
</html>

<script>
  // Smooth scroll for anchor links
  document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
    anchor.addEventListener('click', (e) => {
      const href = (e.currentTarget as HTMLAnchorElement).getAttribute('href');
      if (!href || href === '#') return;
      e.preventDefault();
      document.querySelector(href)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

  // Fade-up on scroll for sections (except hero)
  const sectionObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) entry.target.classList.add('revealed');
      });
    },
    { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('section[id]:not(#home)').forEach((section) => {
    section.classList.add('section-reveal');
    sectionObserver.observe(section);
  });

  // Restore manual scroll
  if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
</script>

<style is:global>
  /* Custom base */
  html {
    scroll-behavior: smooth;
  }

  /* Section scroll offset for fixed nav */
  section[id] {
    scroll-margin-top: 6rem;
  }

  /* Light mode: nav text is dark at ALL times (hero is cream, not dark) */
  :not(.dark) #navbar .nav-logo span:last-child,
  :not(.dark) #navbar .nav-link,
  :not(.dark) #navbar #mobile-menu-btn {
    color: #2c2a28 !important;
  }

  /* Dark mode default: keep text white */
  .dark #navbar .nav-logo span:last-child,
  .dark #navbar .nav-link,
  .dark #navbar #mobile-menu-btn {
    color: #fff !important;
  }

  /* Navbar: warm cream glass when scrolled in light mode */
  #navbar.scrolled {
    background: rgba(254, 249, 244, 0.97);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.06), 0 2px 16px rgba(245, 166, 35, 0.05);
  }

  #navbar.scrolled .nav-logo span:last-child,
  #navbar.scrolled .nav-link {
    color: #2c2a28 !important;
  }

  /* Legacy selector kept for safety */
  #navbar.scrolled .nav-logo {
    color: #2c2a28 !important;
  }

  /* Dark mode scrolled */
  .dark #navbar.scrolled {
    background: rgba(31, 29, 28, 0.95);
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .dark #navbar.scrolled .nav-logo span:last-child,
  .dark #navbar.scrolled .nav-link {
    color: #fff !important;
  }

  .dark #navbar.scrolled .nav-logo {
    color: #fff !important;
  }

  /* nav-light = over a light section — text dark in light mode, white in dark mode */
  #navbar.nav-light .nav-logo span:last-child,
  #navbar.nav-light .nav-logo,
  #navbar.nav-light .nav-link {
    color: #2c2a28 !important;
  }

  #navbar.nav-light.scrolled {
    background: rgba(253, 252, 250, 0.97);
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.07);
  }

  #navbar.nav-light.scrolled .nav-logo,
  #navbar.nav-light.scrolled .nav-link {
    color: #2c2a28 !important;
  }

  /* Dark mode: all sections are dark, keep text white */
  .dark #navbar.nav-light .nav-logo,
  .dark #navbar.nav-light .nav-link {
    color: #fff !important;
  }

  .dark #navbar.nav-light.scrolled {
    background: rgba(31, 29, 28, 0.95);
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .dark #navbar.nav-light.scrolled .nav-logo,
  .dark #navbar.nav-light.scrolled .nav-link {
    color: #fff !important;
  }

  #navbar.nav-light .nav-link:hover {
    color: #ff7a55 !important;
  }

  #navbar.nav-light #mobile-menu-btn,
  #navbar.nav-light #mobile-menu a {
    color: #2c2a28 !important;
  }

  #navbar.nav-light #mobile-menu a:hover {
    color: #ff7a55 !important;
  }

  .dark #navbar.nav-light #mobile-menu-btn,
  .dark #navbar.nav-light #mobile-menu a {
    color: #fff !important;
  }

  /* Theme toggle over light section */
  #navbar.nav-light [data-theme-toggle] {
    border-color: rgba(44, 42, 40, 0.25);
    background: rgba(44, 42, 40, 0.08);
    color: #2c2a28;
  }

  #navbar.nav-light [data-theme-toggle]:hover {
    background: rgba(44, 42, 40, 0.15);
  }

  .dark #navbar.nav-light [data-theme-toggle] {
    border-color: rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
  }

  /* Scrolled nav: theme toggle adapts */
  #navbar.scrolled [data-theme-toggle] {
    border-color: rgba(44, 42, 40, 0.2);
    background: rgba(44, 42, 40, 0.06);
    color: #2c2a28;
  }

  .dark #navbar.scrolled [data-theme-toggle] {
    border-color: rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
  }

  /* Photo cards - modern retro style */
  .photo-card {
    transition: transform 0.4s ease, box-shadow 0.4s ease;
    box-shadow: 0 4px 20px rgba(255, 122, 85, 0.08);
  }

  .photo-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(255, 122, 85, 0.15);
  }

  .photo-card img {
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .photo-card:hover img {
    transform: scale(1.05);
  }

  /* Video cards */
  .video-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 4px 20px rgba(255, 122, 85, 0.08);
  }

  .video-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(255, 122, 85, 0.12);
  }

  /* Form focus — warm glow */
  input:focus,
  textarea:focus {
    outline: none;
    box-shadow: 0 0 0 2px rgba(245, 166, 35, 0.35);
  }

  /* Scrollbar */
  ::-webkit-scrollbar {
    width: 8px;
    height: 8px;
  }

  ::-webkit-scrollbar-track {
    background: #fef9f4;
  }

  .dark ::-webkit-scrollbar-track {
    background: #1f1d1c;
  }

  ::-webkit-scrollbar-thumb {
    background: #a8a4a0;
    border-radius: 4px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: #7a7572;
  }

  /* Reduce motion */
  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }

  /* Mobile menu */
  #mobile-menu {
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  #mobile-menu.show {
    display: block;
  }

  /* Section scroll reveal */
  .section-reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .section-reveal.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  /* Marquee ticker */
  @keyframes ticker {
    from { transform: translateX(0); }
    to   { transform: translateX(-25%); }
  }

  .ticker-track {
    animation: ticker 28s linear infinite;
  }

  .ticker-track:hover {
    animation-play-state: paused;
  }

  /* Prose overrides for About */
  .prose p {
    margin-bottom: 0;
  }

  .prose p + p {
    margin-top: 1rem;
  }
</style>
